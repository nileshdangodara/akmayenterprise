    <!-- ══════════════════ SCRIPTS ══════════════════ -->
    <script>
        /* ── Company data ──────────────────────────────────────────── */

        const companies = JSON.parse(document.getElementById('companies-data').textContent);
        /* ── Helpers ─────────────────────────────────────────────── */
        const sectorColors = { Finance: '#3B82F6', Tech: '#8B5CF6', Healthcare: '#10B981', FMCG: '#F59E0B', Energy: '#EF4444', Infra: '#6B7280' };
        const sectorBg = { Finance: 'rgba(59,130,246,.15)', Tech: 'rgba(139,92,246,.15)', Healthcare: 'rgba(16,185,129,.15)', FMCG: 'rgba(245,158,11,.15)', Energy: 'rgba(239,68,68,.15)', Infra: 'rgba(107,114,128,.15)' };

        function avatarBg(s) { return sectorBg[s] || 'rgba(197,160,89,.15)'; }
        function avatarColor(s) { return sectorColors[s] || '#C5A059'; }

        function changeHTML(c) {
            if (c === null) return `<span class="badge-neutral text-xs px-2 py-0.5 rounded-full">N/A</span>`;
            if (c > 0) return `<span class="badge-up text-xs px-2 py-0.5 rounded-full flex items-center gap-0.5"><span class="material-symbols-outlined text-xs">arrow_upward</span>+${c}%</span>`;
            return `<span class="badge-down text-xs px-2 py-0.5 rounded-full flex items-center gap-0.5"><span class="material-symbols-outlined text-xs">arrow_downward</span>${c}%</span>`;
        }

        function gainColor(g) { return g >= 50 ? '#34D399' : g >= 30 ? '#C5A059' : '#8A9BB0'; }

        /* ── Render grid ─────────────────────────────────────────── */
        function renderGrid(list) {
            const container = document.getElementById('grid-view');
            container.innerHTML = '';
            list.forEach((c, i) => {
                const card = document.createElement('article');
                card.className = 'company-card p-5 flex flex-col' + (c.hot ? ' featured-card' : '');
                card.style.cssText = `animation:fadeUp .5s cubic-bezier(.23,1,.32,1) ${i * 0.04}s both`;
                card.setAttribute('data-id', c.id);
                card.innerHTML = `
      <div class="flex items-start justify-between mb-4">
        <div class="flex items-center gap-3">
          ${c.imglink ? `<img src="${c.imglink}" class="w-11 h-11 rounded-xl object-cover border border-white/10" alt="${c.name}">` : `<div class="logo-avatar" style="background:${avatarBg(c.sector)};color:${avatarColor(c.sector)}">${c.short}</div>`}
          <div>
            <h3 class="text-white font-semibold text-sm leading-tight">${c.name}</h3>
            <span class="sector-tag">${c.sector}</span>
          </div>
        </div>
        ${c.hot ? '<span class="hot-badge">HOT</span>' : ''}
      </div>
      <p class="text-brand-muted text-xs leading-relaxed mb-4 flex-1">${c.desc}</p>
      <div class="grid grid-cols-2 gap-2 mb-4">
        <div class="bg-white/3 rounded-lg p-2.5">
          <p class="text-white/30 text-xs mb-0.5">Price</p>
          <p class="text-white font-semibold text-sm">₹${c.price.toLocaleString('en-IN')}</p>
        </div>
        <div class="bg-white/3 rounded-lg p-2.5">
          <p class="text-white/30 text-xs mb-0.5">52w Chg</p>
          <div>${changeHTML(c.change)}</div>
        </div>
        <div class="bg-white/3 rounded-lg p-2.5">
          <p class="text-white/30 text-xs mb-0.5">Est. Listing Gain</p>
          <p class="font-bold text-sm" style="color:${gainColor(c.gain)}">+${c.gain}%</p>
        </div>
        <div class="bg-white/3 rounded-lg p-2.5">
          <p class="text-white/30 text-xs mb-0.5">Min. Invest</p>
          <p class="text-white font-semibold text-sm">${c.minInv}</p>
        </div>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-xs text-white/25 border border-white/10 px-2 py-0.5 rounded-full">${c.stage}</span>
        <button onclick="openModal('${c._id}')" class="btn-gold px-4 py-2 rounded-lg text-xs flex items-center gap-1 group">
          Enquire <span class="material-symbols-outlined text-xs group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
        </button>
      </div>
    `;
                container.appendChild(card);
            });
        }

        /* ── Render table ────────────────────────────────────────── */
        function renderTable(list) {
            const body = document.getElementById('table-body');
            body.innerHTML = '';
            list.forEach(c => {
                const row = document.createElement('div');
                row.className = 'table-row grid grid-cols-12 gap-4 px-5 py-3.5 items-center';
                row.innerHTML = `
      <div class="col-span-4 flex items-center gap-3">
        ${c.imglink ? `<img src="${c.imglink}" class="w-8 h-8 rounded-lg object-cover border border-white/5" alt="${c.name}">` : `<div class="logo-avatar w-8 h-8 text-xs rounded-lg" style="background:${avatarBg(c.sector)};color:${avatarColor(c.sector)};width:2rem;height:2rem;">${c.short}</div>`}
        <div>
          <p class="text-white text-sm font-medium leading-tight">${c.name}</p>
          <span class="sector-tag">${c.sector}</span>
        </div>
      </div>
      <div class="col-span-2 text-right text-white text-sm font-semibold">₹${c.price.toLocaleString('en-IN')}</div>
      <div class="col-span-2 text-right"><span class="font-bold text-sm" style="color:${gainColor(c.gain)}">+${c.gain}%</span></div>
      <div class="col-span-2 text-right text-brand-muted text-sm">${c.lot}</div>
      <div class="col-span-2 text-right">
        <button onclick="openModal('${c._id}')" class="btn-gold px-3 py-1.5 rounded-lg text-xs">Enquire</button>
      </div>
    `;
                body.appendChild(row);
            });
        }

        /* ── Filter + sort logic ─────────────────────────────────── */
        let currentSector = 'all', currentSort = 'default', currentSearch = '', currentView = 'grid';

        function getFiltered() {
            let list = [...companies];
            if (currentSector !== 'all') list = list.filter(c => c.sector === currentSector);
            if (currentSearch) list = list.filter(c => c.name.toLowerCase().includes(currentSearch) || c.sector.toLowerCase().includes(currentSearch));
            if (currentSort === 'gain-high') list.sort((a, b) => b.gain - a.gain);
            else if (currentSort === 'gain-low') list.sort((a, b) => a.gain - b.gain);
            else if (currentSort === 'price-high') list.sort((a, b) => b.price - a.price);
            else if (currentSort === 'price-low') list.sort((a, b) => a.price - b.price);
            else if (currentSort === 'az') list.sort((a, b) => a.name.localeCompare(b.name));
            else list.sort((a, b) => (b.hot ? 1 : 0) - (a.hot ? 1 : 0));
            return list;
        }

        function render() {
            const list = getFiltered();
            document.getElementById('result-count').textContent = list.length;
            const empty = document.getElementById('empty-state');
            if (!list.length) { empty.classList.remove('hidden'); document.getElementById('grid-view').innerHTML = ''; document.getElementById('table-body').innerHTML = ''; return; }
            empty.classList.add('hidden');
            if (currentView === 'grid') renderGrid(list);
            else renderTable(list);
        }

        function resetFilters() {
            currentSector = 'all'; currentSearch = ''; currentSort = 'default';
            document.getElementById('search-input').value = '';
            document.getElementById('sort-select').value = 'default';
            document.querySelectorAll('.filter-pill').forEach(p => { p.classList.toggle('active', p.dataset.sector === 'all'); });
            render();
        }

        /* ── Event listeners ─────────────────────────────────────── */
        document.getElementById('search-input').addEventListener('input', e => { currentSearch = e.target.value.toLowerCase().trim(); render(); });
        document.getElementById('sort-select').addEventListener('change', e => { currentSort = e.target.value; render(); });
        document.querySelectorAll('.filter-pill').forEach(btn => {
            btn.addEventListener('click', () => {
                currentSector = btn.dataset.sector;
                document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
                btn.classList.add('active'); render();
            });
        });

        /* View toggle */
        document.getElementById('view-grid').addEventListener('click', () => {
            currentView = 'grid';
            document.getElementById('grid-view').classList.remove('hidden'); document.getElementById('table-view').classList.add('hidden');
            document.getElementById('view-grid').classList.add('active'); document.getElementById('view-table').classList.remove('active');
            render();
        });
        document.getElementById('view-table').addEventListener('click', () => {
            currentView = 'table';
            document.getElementById('table-view').classList.remove('hidden'); document.getElementById('grid-view').classList.add('hidden');
            document.getElementById('view-table').classList.add('active'); document.getElementById('view-grid').classList.remove('active');
            render();
        });

        /* ── Modal ───────────────────────────────────────────────── */
        function openModal(id) {
            const modal = document.getElementById('enquiry-modal');
            const banner = document.getElementById('modal-company-banner');
            if (id) {
                const c = companies.find(x => x._id === id);
                if (c) {
                    const modalLogo = document.getElementById('modal-logo');
                    if (c.imglink) {
                        modalLogo.innerHTML = `<img src="${c.imglink}" class="w-full h-full rounded-xl object-cover" alt="${c.name}">`;
                        modalLogo.style.background = 'transparent';
                    } else {
                        modalLogo.textContent = c.short;
                        modalLogo.style.background = avatarBg(c.sector);
                        modalLogo.style.color = avatarColor(c.sector);
                    }
                    document.getElementById('modal-company-name').textContent = c.name;
                    document.getElementById('modal-company-meta').textContent = `${c.sector} · ₹${c.price.toLocaleString('en-IN')} · Min ${c.minInv}`;
                    document.getElementById('m-stock').value = c.name;
                    const badge = document.getElementById('modal-company-badge');
                    badge.textContent = `+${c.gain}% est.`;
                    badge.className = 'ml-auto text-xs font-bold px-2 py-1 rounded-lg';
                    badge.style.cssText = `background:rgba(52,211,153,.1);color:#34D399;border:1px solid rgba(52,211,153,.25)`;
                    banner.classList.remove('hidden');
                }
            } else { 
                banner.classList.add('hidden'); 
                document.getElementById('m-stock').value = 'General Enquiry';
            }
            modal.classList.add('open');
            document.body.style.overflow = 'hidden';
        }
        function closeModal() {
            document.getElementById('enquiry-modal').classList.remove('open');
            document.body.style.overflow = '';
        }
        document.getElementById('enquiry-modal').addEventListener('click', e => { if (e.target === document.getElementById('enquiry-modal')) closeModal(); });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

        /* ── Modal form ──────────────────────────────────────────── */
        document.getElementById('modal-form').addEventListener('submit', async e => {
            e.preventDefault();

            // Validate
            const nameEl = document.getElementById('m-name');
            const phoneEl = document.getElementById('m-phone');
            const nameErr = document.getElementById('m-name-err');
            const phoneErr = document.getElementById('m-phone-err');
            let valid = true;

            if (!nameEl.value.trim()) {
                nameErr.classList.remove('hidden');
                nameEl.style.borderBottomColor = '#f87171';
                valid = false;
            } else {
                nameErr.classList.add('hidden');
                nameEl.style.borderBottomColor = '';
            }

            if (!phoneEl.value.trim()) {
                phoneErr.classList.remove('hidden');
                phoneEl.style.borderBottomColor = '#f87171';
                valid = false;
            } else {
                phoneErr.classList.add('hidden');
                phoneEl.style.borderBottomColor = '';
            }

            if (!valid) return;

            const btn = document.getElementById('modal-btn-text');
            const submitBtn = document.getElementById('modal-submit');
            btn.textContent = 'Sending…';
            submitBtn.disabled = true;

            try {
                const payload = {
                    formSource: 'Pre-IPO Enquiry',
                    fullName: nameEl.value.trim(),
                    phoneNumber: phoneEl.value.trim(),
                    stockInterest: document.getElementById('m-stock').value || 'General Enquiry'
                };
                const res = await fetch('/send-email', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (!res.ok) throw new Error('Failed');
                document.getElementById('modal-form').reset();
                document.getElementById('m-stock').value = '';
                closeModal();
                const ov = document.getElementById('success-overlay');
                ov.style.display = 'flex';
            } catch (err) {
                alert('An error occurred. Please try again.');
            } finally {
                btn.textContent = 'Submit Enquiry';
                submitBtn.disabled = false;
            }
        });

        /* ── Scroll behaviours ───────────────────────────────────── */
        const nav = document.getElementById('topnav');
        const floatCta = document.getElementById('float-cta');
        window.addEventListener('scroll', () => {
            nav.classList.toggle('scrolled', window.scrollY > 60);
            floatCta.classList.toggle('show', window.scrollY > 400);
        });

        /* ── Scroll reveal ───────────────────────────────────────── */
        const rvio = new IntersectionObserver(entries => { entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('up'); rvio.unobserve(e.target); } }); }, { threshold: .1 });
        document.querySelectorAll('.reveal').forEach(el => rvio.observe(el));

        /* ── Init ─────────────────────────────────────────────────── */
        render();

        /* ── Newsletter Subscription ── */
        const subscribeBtn = document.getElementById('subscribe-btn');
        const emailInput = document.getElementById('subscriber-email');

        if (subscribeBtn && emailInput) {
            subscribeBtn.addEventListener('click', async () => {
                const email = emailInput.value.trim();
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                if (!email || !emailRegex.test(email)) {
                    alert('Please enter a valid email address.');
                    return;
                }

                try {
                    subscribeBtn.disabled = true;
                    subscribeBtn.textContent = 'Subscribing...';

                    const response = await fetch('/subscribe', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({ email })
                    });

                    const result = await response.json();

                    if (response.ok) {
                        alert(result.message);
                        emailInput.value = '';
                    } else {
                        alert(result.message || "Something went wrong. Please try again.");
                    }
                } catch (error) {
                    console.error("Subscription Error:", error);
                    alert("Failed to connect to the server. Please check your connection.");
                } finally {
                    subscribeBtn.disabled = false;
                    subscribeBtn.textContent = 'Subscribe';
                }
            });
        }
    </script>
</body>

</html>