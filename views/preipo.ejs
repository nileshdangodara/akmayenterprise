            transition: background-position .5s, transform .2s, box-shadow .3s;
        }

        .btn-gold:hover {
            background-position: right center;
            transform: translateY(-2px);
            box-shadow: 0 16px 40px rgba(197, 160, 89, .3);
        }

        .btn-ghost {
            border: 1px solid rgba(197, 160, 89, .45);
            color: var(--gold2);
            font-weight: 600;
            transition: background .3s, border-color .3s, transform .2s;
        }

        .btn-ghost:hover {
            background: rgba(197, 160, 89, .08);
            border-color: rgba(197, 160, 89, .7);
            transform: translateY(-2px);
        }

        .sec-label {
            font-size: .65rem;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: rgba(197, 160, 89, .6);
            font-weight: 600;
        }

        /* Search */
        input[type="text"].search-box {
            background: rgba(255, 255, 255, .04);
            border: 1px solid rgba(197, 160, 89, .2);
            color: #fff;
            transition: border-color .3s, background .3s, box-shadow .3s;
        }

        input[type="text"].search-box:focus {
            outline: none;
            border-color: rgba(197, 160, 89, .6);
            background: rgba(255, 255, 255, .06);
            box-shadow: 0 0 0 1px rgba(197, 160, 89, .6);
        }

        input[type="text"].search-box::placeholder {
            color: rgba(240, 244, 248, .25);
        }

        /* Filter pills */
        .filter-pill {
            border: 1px solid rgba(197, 160, 89, .2);
            color: rgba(240, 244, 248, .5);
            font-size: .75rem;
            font-weight: 500;
            padding: .35rem .9rem;
            border-radius: 9999px;
            cursor: pointer;
            transition: background .2s, border-color .2s, color .2s;
            background: transparent;
        }

        .filter-pill:hover,
        .filter-pill.active {
            background: rgba(197, 160, 89, .12);
            border-color: rgba(197, 160, 89, .5);
            color: #C5A059;
        }

        .filter-pill.active {
            background: rgba(197, 160, 89, .18);
        }

        /* Sort select */
        .sort-select {
            background: rgba(255, 255, 255, .04);
            border: 1px solid rgba(197, 160, 89, .2);
            color: rgba(240, 244, 248, .6);
            border-radius: .5rem;
            padding: .4rem .8rem;
            font-size: .75rem;
            font-family: "DM Sans", sans-serif;
            cursor: pointer;
            outline: none;
            transition: border-color .3s;
        }

        .sort-select:focus {
            border-color: rgba(197, 160, 89, .5);
        }

        .sort-select option {
            background: #0D1E38;
        }

        /* Company card */
        .company-card {
            border: 1px solid rgba(197, 160, 89, .1);
            background: rgba(255, 255, 255, .022);
            border-radius: 1rem;
            transition: border-color .3s, background .3s, transform .4s cubic-bezier(.23, 1, .32, 1), box-shadow .3s;
            cursor: pointer;
            overflow: hidden;
            position: relative;
        }

        .company-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at top right, rgba(197, 160, 89, .05), transparent 65%);
            opacity: 0;
            transition: opacity .35s;
            pointer-events: none;
        }

        .company-card:hover {
            border-color: rgba(197, 160, 89, .4);
            background: rgba(197, 160, 89, .035);
            transform: translateY(-4px);
            box-shadow: 0 24px 48px rgba(0, 0, 0, .4);
        }

        .company-card:hover::before {
            opacity: 1;
        }

        .company-card.featured-card {
            border-color: rgba(197, 160, 89, .3);
            background: linear-gradient(145deg, rgba(197, 160, 89, .1), rgba(197, 160, 89, .03));
        }

        /* Logo avatar */
        .logo-avatar {
            width: 2.75rem;
            height: 2.75rem;
            border-radius: .625rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: "Cormorant Garamond", serif;
            font-weight: 700;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        /* Change badge */
        .badge-up {
            background: rgba(52, 211, 153, .1);
            border: 1px solid rgba(52, 211, 153, .25);
            color: #34D399;
        }

        .badge-down {
            background: rgba(248, 113, 113, .1);
            border: 1px solid rgba(248, 113, 113, .25);
            color: #F87171;
        }

        .badge-neutral {
            background: rgba(197, 160, 89, .12);
            border: 1px solid rgba(197, 160, 89, .3);
            color: #C5A059;
        }

        /* Sector tag */
        .sector-tag {
            font-size: .6rem;
            letter-spacing: .1em;
            text-transform: uppercase;
            padding: .2rem .6rem;
            border-radius: 9999px;
            border: 1px solid rgba(197, 160, 89, .2);
            color: rgba(197, 160, 89, .6);
            background: rgba(197, 160, 89, .05);
        }

        /* Hot badge */
        .hot-badge {
            background: linear-gradient(135deg, #C5A059, #E5D5B7);
            color: #08152A;
            font-size: .55rem;
            font-weight: 800;
            letter-spacing: .1em;
            text-transform: uppercase;
            padding: .2rem .5rem;
            border-radius: 9999px;
        }

        /* Scroll reveal */
        .reveal {
            opacity: 0;
            transform: translateY(20px);
            transition: opacity .6s ease, transform .6s cubic-bezier(.23, 1, .32, 1);
        }

        .reveal.up {
            opacity: 1;
            transform: none;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(30px)
            }

            to {
                opacity: 1;
                transform: none
            }
        }

        @keyframes spin {
            to {
                transform: rotate(360deg)
            }
        }

        .h-anim-1 {
            animation: fadeUp .8s cubic-bezier(.23, 1, .32, 1) .1s both;
        }

        .h-anim-2 {
            animation: fadeUp .8s cubic-bezier(.23, 1, .32, 1) .25s both;
        }

        .h-anim-3 {
            animation: fadeUp .8s cubic-bezier(.23, 1, .32, 1) .4s both;
        }

        /* Modal */
        #enquiry-modal {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(8, 21, 42, .85);
            backdrop-filter: blur(12px);
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        #enquiry-modal.open {
            display: flex;
        }

        .modal-box {
            background: linear-gradient(145deg, #0D1E38, #08152A);
            border: 1px solid rgba(197, 160, 89, .25);
            border-radius: 1.5rem;
            padding: 2rem;
            max-width: 480px;
            width: 100%;
            position: relative;
            max-height: 90vh;
            overflow-y: auto;
        }

        @keyframes modalIn {
            from {
                opacity: 0;
                transform: scale(.93) translateY(20px)
            }

            to {
                opacity: 1;
                transform: none
            }
        }

        .modal-box {
            animation: modalIn .35s cubic-bezier(.23, 1, .32, 1) both;
        }

        /* Form fields */
        .modal-field {
            position: relative;
            margin-bottom: 1.5rem;
        }

        .modal-field input,
        .modal-field select,
        .modal-field textarea {
            width: 100%;
            background: rgba(255, 255, 255, .04);
            border: none;
            border-bottom: 1px solid rgba(197, 160, 89, .3);
            padding: 1.3rem 0 .4rem;
            font-size: .85rem;
            color: #F0F4F8;
            outline: none;
            transition: border-color .3s;
            font-family: "DM Sans", sans-serif;
            resize: none;
        }

        .modal-field select option {
            background: #0D1E38;
        }

        .modal-field input:focus,
        .modal-field select:focus,
        .modal-field textarea:focus {
            border-bottom-color: #C5A059;
        }

        .modal-field label {
            position: absolute;
            top: 1.2rem;
            left: 0;
            font-size: .8rem;
            color: rgba(240, 244, 248, .35);
            pointer-events: none;
            transition: top .25s, font-size .25s, color .25s;
        }

        .modal-field input:focus~label,
        .modal-field input:not(:placeholder-shown)~label,
        .modal-field textarea:focus~label,
        .modal-field textarea:not(:placeholder-shown)~label,
        .modal-field.filled label {
            top: .05rem;
            font-size: .65rem;
            color: #C5A059;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .modal-field .ubar {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 1px;
            background: #C5A059;
            transition: width .4s cubic-bezier(.23, 1, .32, 1);
        }

        .modal-field input:focus~.ubar,
        .modal-field select:focus~.ubar,
        .modal-field textarea:focus~.ubar {
            width: 100%;
        }

        /* Marquee */
        .marquee-wrap {
            overflow: hidden;
        }

        .marquee-inner {
            display: flex;
            gap: 3rem;
            white-space: nowrap;
            animation: ticker 30s linear infinite;
        }

        @keyframes ticker {
            from {
                transform: translateX(0)
            }

            to {
                transform: translateX(-50%)
            }
        }

        /* Float CTA */
        #float-cta {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            z-index: 90;
            opacity: 0;
            transform: translateY(10px);
            transition: opacity .4s, transform .4s;
            pointer-events: none;
        }

        #float-cta.show {
            opacity: 1;
            transform: none;
            pointer-events: auto;
        }

        /* Tabs */
        .view-tab {
            padding: .4rem 1rem;
            border-radius: .5rem;
            font-size: .75rem;
            font-weight: 500;
            cursor: pointer;
            transition: background .2s, color .2s;
            color: rgba(240, 244, 248, .4);
        }

        .view-tab.active {
            background: rgba(197, 160, 89, .15);
            color: #C5A059;
        }

        /* Skeleton */
        .skeleton {
            background: linear-gradient(90deg, rgba(255, 255, 255, .04) 25%, rgba(255, 255, 255, .08) 50%, rgba(255, 255, 255, .04) 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
        }

        @keyframes shimmer {
            0% {
                background-position: 200% 0
            }

            100% {
                background-position: -200% 0
            }
        }

        /* Table row */
        .table-row {
            border-bottom: 1px solid rgba(197, 160, 89, .06);
            transition: background .2s;
        }

        .table-row:hover {
            background: rgba(197, 160, 89, .04);
        }

        .table-row:last-child {
            border-bottom: none;
        }

        ::-webkit-scrollbar {
            width: 4px;
        }

        ::-webkit-scrollbar-track {
            background: var(--navy);
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(197, 160, 89, .4);
            border-radius: 2px;
        }

        /* Search input */
        input[type="text"].search-box {
            background: rgba(255, 255, 255, .04);
            border: 1px solid rgba(197, 160, 89, .2);
            color: #fff;
            transition: border-color .3s, background .3s, box-shadow .3s;
        }

        input[type="text"].search-box:focus {
            outline: none;
            border-color: rgba(197, 160, 89, .6);
            background: rgba(255, 255, 255, .06);
            box-shadow: 0 0 0 1px rgba(197, 160, 89, .6);
        }

        input[type="text"].search-box::placeholder {
            color: rgba(240, 244, 248, .25);
        }
    </style>
</head>

