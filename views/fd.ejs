    <!-- ══════════════════════ SCRIPTS ══════════════════════ -->
    <script>
        /* ── FD Data ── */

        const fds = JSON.parse(document.getElementById('fds-data').textContent);
        const heroRateData = [
            { name: 'Shriram Finance', rate: 9.40, label: 'AA+', cls: 'safe-aa' },
            { name: 'Muthoot Capital', rate: 9.00, label: 'AA', cls: 'safe-a' },
            { name: 'Godrej Housing Finance', rate: 8.75, label: 'AA+', cls: 'safe-aa' },
            { name: 'Bajaj Finance', rate: 8.85, label: 'AAA', cls: 'safe-aaa' },
        ];

        /* ── Hero rate rows ── */
        const heroRatesEl = document.getElementById('hero-rates');
        heroRateData.forEach(r => {
            const row = document.createElement('div');
            row.className = 'flex items-center justify-between py-2.5 border-b border-brand-gold/8 last:border-0';
            row.innerHTML = `
    <div class="flex items-center gap-2.5">
      <span class="text-xs px-2 py-0.5 rounded-full font-semibold ${r.cls}">${r.label}</span>
      <span class="text-white text-sm">${r.name}</span>
    </div>
    <div class="flex items-center gap-3">
      <div class="w-20 rate-bar-bg hidden sm:block"><div class="rate-bar-fill" style="width:${((r.rate - 6.5) / 3.5) * 100}%"></div></div>
      <span class="font-display text-brand-gold font-bold text-lg">${r.rate}%</span>
    </div>
  `;
            heroRatesEl.appendChild(row);
        });

        /* ── Comparison table ── */
        const cmpData = [
            ['Typical interest rate', '6.5–7.5% p.a.', '7.5–9.5% p.a.'],
            ['DICGC deposit insurance', 'Up to ₹5 Lakhs', 'Not covered'],
            ['Credit rating', 'Govt-backed', 'AAA / AA+ (CRISIL/ICRA)'],
            ['Senior citizen benefit', '0.25–0.50%', '0.25–0.50%'],
            ['Premature withdrawal', 'Generally available', 'Allowed after min. lock-in'],
            ['Loan against FD', 'Yes', 'Yes (select issuers)'],
            ['Return certainty', 'Fixed', 'Fixed'],
        ];
        const cmpTable = document.getElementById('cmp-table');
        cmpData.forEach(r => {
            const row = document.createElement('div');
            row.className = 'tbl-row grid px-5 py-3.5 text-xs items-center';
            row.style.gridTemplateColumns = '1.5fr 1fr 1fr';
            row.innerHTML = `<div class="text-white/60">${r[0]}</div><div class="text-center text-white/40">${r[1]}</div><div class="text-center text-brand-gold font-medium">${r[2]}</div>`;
            cmpTable.appendChild(row);
        });

        /* ── FAQs ── */
        const faqs = [
            { q: 'Are corporate FDs safe?', a: 'Top-rated corporate FDs (AAA/AA+) have an excellent track record of timely repayment. AKMAY only recommends FDs from issuers with strong credit ratings from CRISIL, ICRA or CARE. Unlike bank FDs, corporate FDs are not covered by DICGC insurance — which is why credit rating analysis is critical.' },
            { q: 'What is the minimum investment for a corporate FD?', a: 'Minimums vary by issuer — typically starting at ₹5,000 (Shriram Finance), ₹10,000 (Bajaj Finance, PNB Housing) or ₹25,000 (HDFC, Tata Capital). AKMAY recommends spreading investments across 2–3 issuers for diversification.' },
            { q: 'How is the interest taxed on FDs?', a: 'Interest earned on FDs is added to your total income and taxed at applicable slab rates. TDS is deducted at 10% when annual interest exceeds ₹5,000. You may submit Form 15G/H to avoid TDS if your total income is below the taxable limit.' },
            { q: 'Can I withdraw before maturity?', a: 'Most corporate FDs allow premature withdrawal after a minimum lock-in period (usually 3–6 months), subject to a small penalty on the interest rate (typically 1–2%). AKMAY advises clients to align FD tenure with liquidity requirements.' },
            { q: 'What is the difference between cumulative and non-cumulative FDs?', a: 'Cumulative FDs reinvest interest and pay the lump sum (principal + compound interest) at maturity — ideal for wealth growth. Non-cumulative FDs pay interest periodically (monthly/quarterly/annually) — ideal for regular income needs.' },
            { q: 'Do senior citizens get a higher rate?', a: 'Yes. Most issuers offer an additional 0.25–0.50% p.a. for investors aged 60 and above. On a ₹25 Lakh investment at 9.5% over 5 years, even 0.25% extra translates to approximately ₹35,000–40,000 in additional income.' },
        ];
        const faqContainer = document.getElementById('faq-container');
        faqs.forEach((f, i) => {
            const el = document.createElement('details');
            el.className = 'faq-item reveal group';
            el.style.transitionDelay = `${i * 0.04}s`;
            el.innerHTML = `<summary class="flex items-center justify-between p-5 cursor-pointer list-none gap-3"><span class="text-white font-medium text-sm">${f.q}</span><span class="faq-icon material-symbols-outlined text-brand-gold flex-shrink-0">add</span></summary><div class="px-5 pb-5 text-brand-muted text-sm leading-relaxed">${f.a}</div>`;
            faqContainer.appendChild(el);
        });

        /* ── Filter state ── */
        let currentType = 'all', currentSort = 'default', currentSearch = '', currentView = 'grid';

        function getFiltered() {
            let list = [...fds];
            if (currentType !== 'all') list = list.filter(f => f.type === currentType);
            if (currentSearch) list = list.filter(f => f.name.toLowerCase().includes(currentSearch));
            if (currentSort === 'rate-high') list.sort((a, b) => b.rate - a.rate);
            else if (currentSort === 'rate-low') list.sort((a, b) => a.rate - b.rate);
            else if (currentSort === 'az') list.sort((a, b) => a.name.localeCompare(b.name));
            else list.sort((a, b) => (b.top ? 1 : 0) - (a.top ? 1 : 0));
            return list;
        }

        function renderGrid(list) {
            const c = document.getElementById('grid-view');
            c.innerHTML = '';
            list.forEach((f, i) => {
                const card = document.createElement('article');
                card.className = `fd-card p-6 flex flex-col${f.top ? ' top-pick' : ''}`;
                card.style.animation = `fadeUp .5s cubic-bezier(.23,1,.32,1) ${i * 0.04}s both`;
                card.innerHTML = `
      <div class="flex items-start justify-between mb-4">
        <div class="flex gap-4">
          ${f.imglink ? `<img src="${f.imglink}" class="w-12 h-12 rounded-xl object-cover border border-white/10" alt="${f.name}">` : `<div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold font-bold">${f.name.substring(0, 2).toUpperCase()}</div>`}
          <div>
            <div class="flex items-center gap-2 mb-1">
              <h3 class="text-white font-semibold text-sm leading-tight">${f.name}</h3>
              ${f.top ? '<span style="background:linear-gradient(135deg,#C5A059,#E5D5B7);color:#08152A;font-size:.55rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;padding:.2rem .5rem;border-radius:9999px;">TOP PICK</span>' : ''}
            </div>
            <span class="text-xs ${f.ratingClass} px-2 py-0.5 rounded-full font-semibold">${f.ratingLabel} Rated · ${f.type}</span>
          </div>
        </div>
        <div class="text-right flex-shrink-0 ml-3">
          <p class="font-display text-3xl text-brand-gold font-bold leading-none">${f.rate}%</p>
          <p class="text-white/30 text-xs mt-0.5">p.a.</p>
        </div>
      </div>
      <p class="text-brand-muted text-xs leading-relaxed mb-4 flex-1">${f.desc}</p>
      <div class="mb-4">
        <div class="flex justify-between text-xs mb-1"><span class="text-white/30">Interest Rate</span><span class="text-brand-gold font-semibold">${f.rate}%</span></div>
        <div class="rate-bar-bg"><div class="rate-bar-fill" style="width:${((f.rate - 6.5) / 3.5) * 100}%"></div></div>
      </div>
      <div class="grid grid-cols-3 gap-2 mb-4">
        <div class="bg-white/3 rounded-lg p-2 text-center">
          <p class="text-white/30 text-xs">Senior</p>
          <p class="text-emerald-400 font-semibold text-xs">${f.seniorRate}%</p>
        </div>
        <div class="bg-white/3 rounded-lg p-2 text-center">
          <p class="text-white/30 text-xs">Tenure</p>
          <p class="text-white text-xs font-semibold">${f.tenure}</p>
        </div>
        <div class="bg-white/3 rounded-lg p-2 text-center">
          <p class="text-white/30 text-xs">Min. Inv.</p>
          <p class="text-white text-xs font-semibold">${f.minInv}</p>
        </div>
      </div>
      <button onclick="openModal(${f.id})" class="btn-gold w-full py-2.5 rounded-lg text-xs flex items-center justify-center gap-1.5 group">
        Invest Now <span class="material-symbols-outlined text-xs group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
      </button>
    `;
                c.appendChild(card);
            });
        }

        function renderTable(list) {
            const b = document.getElementById('table-body');
            b.innerHTML = '';
            list.forEach(f => {
                const row = document.createElement('div');
                row.className = 'tbl-row grid items-center px-5 py-3.5';
                row.style.gridTemplateColumns = '2fr 1fr 1fr 1fr 1fr 1fr';
                row.innerHTML = `
      <div class="flex items-center gap-3">
        ${f.imglink ? `<img src="${f.imglink}" class="w-8 h-8 rounded-lg object-cover border border-white/5" alt="${f.name}">` : `<div class="w-8 h-8 rounded-lg bg-brand-gold/10 flex items-center justify-center text-brand-gold text-[10px] font-bold">${f.name.substring(0, 2).toUpperCase()}</div>`}
        <div>
          <p class="text-white text-sm font-medium">${f.name}</p>
          <span class="text-[10px] ${f.ratingClass} px-1.5 py-0.5 rounded-full">${f.ratingLabel} · ${f.type}</span>
        </div>
      </div>
      <div class="text-right font-display text-brand-gold font-bold text-lg">${f.rate}%</div>
      <div class="text-right text-emerald-400 text-sm font-semibold">${f.seniorRate}%</div>
      <div class="text-right text-brand-muted text-sm">${f.tenure}</div>
      <div class="text-right text-brand-muted text-sm">${f.minInv}</div>
      <div class="text-right"><button onclick="openModal(${f.id})" class="btn-gold px-3 py-1.5 rounded-lg text-xs">Invest</button></div>
    `;
                b.appendChild(row);
            });
        }

        function renderFDs() {
            const list = getFiltered();
            document.getElementById('fd-count').textContent = list.length;
            const empty = document.getElementById('empty-state');
            if (!list.length) { empty.classList.remove('hidden'); document.getElementById('grid-view').innerHTML = ''; document.getElementById('table-body').innerHTML = ''; return; }
            empty.classList.add('hidden');
            if (currentView === 'grid') renderGrid(list);
            else renderTable(list);
        }

        function resetFDFilters() {
            currentType = 'all'; currentSearch = ''; currentSort = 'default';
            document.getElementById('fd-search').value = '';
            document.getElementById('fd-sort').value = 'default';
            document.querySelectorAll('.type-pill').forEach(p => p.classList.toggle('active', p.dataset.type === 'all'));
            renderFDs();
        }

        /* Events */
        document.getElementById('fd-search').addEventListener('input', e => { currentSearch = e.target.value.toLowerCase().trim(); renderFDs(); });
        document.getElementById('fd-sort').addEventListener('change', e => { currentSort = e.target.value; renderFDs(); });
        document.querySelectorAll('.type-pill').forEach(btn => {
            btn.addEventListener('click', () => {
                currentType = btn.dataset.type;
                document.querySelectorAll('.type-pill').forEach(p => p.classList.remove('active'));
                btn.classList.add('active');
                renderFDs();
            });
        });
        document.getElementById('vg').addEventListener('click', () => {
            currentView = 'grid';
            document.getElementById('grid-view').classList.remove('hidden');
            document.getElementById('table-view').classList.add('hidden');
            document.getElementById('vg').classList.add('active');
            document.getElementById('vt').classList.remove('active');
            renderFDs();
        });
        document.getElementById('vt').addEventListener('click', () => {
            currentView = 'table';
            document.getElementById('table-view').classList.remove('hidden');
            document.getElementById('grid-view').classList.add('hidden');
            document.getElementById('vt').classList.add('active');
            document.getElementById('vg').classList.remove('active');
            renderFDs();
        });

        /* ── Calculator ── */
        let calcFreq = 1;
        function fmtINR(n) {
            return '₹' + Math.round(n).toLocaleString('en-IN');
        }
        function calcFD() {
            const P = parseFloat(document.getElementById('sl-principal').value);
            const r = parseFloat(document.getElementById('sl-rate').value);
            const t = parseFloat(document.getElementById('sl-tenure').value) / 12;
            const n = calcFreq;
            const maturity = P * Math.pow(1 + (r / 100) / n, n * t);
            const interest = maturity - P;
            const roi = (interest / P) * 100;
            const eay = (Math.pow(1 + (r / 100) / n, n) - 1) * 100;
            document.getElementById('result-maturity').textContent = fmtINR(maturity);
            document.getElementById('result-principal').textContent = fmtINR(P);
            document.getElementById('result-interest').textContent = fmtINR(interest);
            document.getElementById('result-yield').textContent = eay.toFixed(2) + '%';
            document.getElementById('result-roi').textContent = roi.toFixed(1) + '%';
            document.getElementById('disp-principal').textContent = fmtINR(P);
            document.getElementById('disp-rate').textContent = r.toFixed(1) + '%';
            document.getElementById('disp-tenure').textContent = document.getElementById('sl-tenure').value + ' months';
            // Donut
            const circ = 2 * Math.PI * 90;
            const pPct = P / maturity;
            const iPct = interest / maturity;
            document.getElementById('donut-principal').setAttribute('stroke-dasharray', `${pPct * circ} ${circ - pPct * circ}`);
            document.getElementById('donut-principal').setAttribute('stroke-dashoffset', '0');
            document.getElementById('donut-interest').setAttribute('stroke-dasharray', `${iPct * circ} ${circ - iPct * circ}`);
            document.getElementById('donut-interest').setAttribute('stroke-dashoffset', `${-pPct * circ}`);
        }
        ['sl-principal', 'sl-rate', 'sl-tenure'].forEach(id => document.getElementById(id).addEventListener('input', calcFD));
        document.querySelectorAll('.comp-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                calcFreq = parseInt(btn.dataset.freq);
                document.querySelectorAll('.comp-btn').forEach(b => {
                    b.classList.remove('active', 'text-brand-gold', 'bg-brand-gold/10', 'border-brand-gold/30');
                    b.classList.add('text-white/40', 'border-white/10');
                });
                btn.classList.add('active', 'text-brand-gold', 'bg-brand-gold/10', 'border-brand-gold/30');
                btn.classList.remove('text-white/40', 'border-white/10');
                calcFD();
            });
        });
        calcFD();

        /* ── Modal ── */
        function openModal(id) {
            const banner = document.getElementById('modal-fd-banner');
            if (id) {
                const f = fds.find(x => x.id === id);
                if (f) {
                    document.getElementById('modal-fd-name').textContent = f.name;
                    document.getElementById('modal-fd-meta').textContent = `${f.type} · ${f.ratingLabel} Rated · Min ${f.minInv}`;
                    document.getElementById('modal-fd-rate').textContent = f.rate + '%';
                    banner.classList.remove('hidden');
                    banner.classList.add('flex');
                }
            } else { banner.classList.add('hidden'); banner.classList.remove('flex'); }
            document.getElementById('invest-modal').classList.add('open');
            document.body.style.overflow = 'hidden';
        }
        function closeModal() {
            document.getElementById('invest-modal').classList.remove('open');
            document.body.style.overflow = '';
        }
        document.getElementById('invest-modal').addEventListener('click', e => { if (e.target === document.getElementById('invest-modal')) closeModal(); });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

        document.getElementById('modal-form').addEventListener('submit', async e => {
            e.preventDefault();
            const txt = document.getElementById('m-btn-txt');
            const spin = document.getElementById('m-spin');
            txt.textContent = 'Sending…';
            spin.classList.remove('hidden');
            await new Promise(r => setTimeout(r, 1700));
            spin.classList.add('hidden');
            txt.textContent = 'Submit Interest';
            closeModal();
            document.getElementById('modal-form').reset();
            document.getElementById('success-overlay').classList.add('show');
        });
        ['m-amount', 'm-tenure'].forEach(id => {
            document.getElementById(id).addEventListener('change', function () {
                this.closest('.mf').classList.toggle('filled', !!this.value);
            });
        });

        /* ── Nav + scroll ── */
        const nav = document.getElementById('topnav');
        const floatCta = document.getElementById('float-cta');
        window.addEventListener('scroll', () => {
            nav.classList.toggle('scrolled', window.scrollY > 60);
            floatCta.classList.toggle('show', window.scrollY > 400);
        });

        /* ── Reveal ── */
        const rvio = new IntersectionObserver(entries => {
            entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('up'); rvio.unobserve(e.target); } });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal,.reveal-l,.reveal-r,.faq-item').forEach(el => rvio.observe(el));

        /* ── Init ── */
        renderFDs();

        /* ── Newsletter Subscription ── */
        const subscribeBtn = document.getElementById('subscribe-btn');
        const emailInput = document.getElementById('subscriber-email');

        if (subscribeBtn && emailInput) {
            subscribeBtn.addEventListener('click', async () => {
                const email = emailInput.value.trim();
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                if (!email || !emailRegex.test(email)) {
                    alert('Please enter a valid email address.');
                    return;
                }

                try {
                    subscribeBtn.disabled = true;
                    subscribeBtn.textContent = 'Subscribing...';

                    const response = await fetch('/subscribe', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({ email })
                    });

                    const result = await response.json();

                    if (response.ok) {
                        alert(result.message);
                        emailInput.value = '';
                    } else {
                        alert(result.message || "Something went wrong. Please try again.");
                    }
                } catch (error) {
                    console.error("Subscription Error:", error);
                    alert("Failed to connect to the server. Please check your connection.");
                } finally {
                    subscribeBtn.disabled = false;
                    subscribeBtn.textContent = 'Subscribe';
                }
            });
        }
    </script>
</body>

</html>