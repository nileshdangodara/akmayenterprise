            background: rgba(13, 30, 56, 0.7);
            transform: translateY(-5px);
            box-shadow: 0 12px 32px rgba(197, 160, 89, .08);
        }

        .fd-card:hover::before {
            opacity: 0;
        }

        .fd-card.top-pick {
            border-color: rgba(197, 160, 89, .3);
            background: rgba(13, 30, 56, 0.65);
            box-shadow: 0 4px 16px rgba(197, 160, 89, .1);
        }

        .fd-card.top-pick:hover {
            border-color: rgba(197, 160, 89, .4);
            background: rgba(13, 30, 56, 0.75);
            box-shadow: 0 16px 40px rgba(197, 160, 89, .15);
        }

        /* Safety badge */
        .safe-aaa {
            background: rgba(52, 211, 153, .1);
            border: 1px solid rgba(52, 211, 153, .25);
            color: #34D399;
        }

        .safe-aa {
            background: rgba(96, 165, 250, .1);
            border: 1px solid rgba(96, 165, 250, .25);
            color: #60A5FA;
        }

        .safe-a {
            background: rgba(251, 191, 36, .1);
            border: 1px solid rgba(251, 191, 36, .25);
            color: #FBBF24;
        }

        /* Type filter */
        .type-pill {
            border: 1px solid rgba(197, 160, 89, .2);
            color: rgba(240, 244, 248, .5);
            font-size: .75rem;
            font-weight: 500;
            padding: .35rem .9rem;
            border-radius: 9999px;
            cursor: pointer;
            transition: background .2s, border-color .2s, color .2s;
            background: transparent;
        }

        .type-pill:hover,
        .type-pill.active {
            background: rgba(197, 160, 89, .12);
            border-color: rgba(197, 160, 89, .5);
            color: #C5A059;
        }

        /* Sort */
        .sort-sel {
            background: rgba(255, 255, 255, .04);
            border: 1px solid rgba(197, 160, 89, .2);
            color: rgba(240, 244, 248, .6);
            border-radius: .5rem;
