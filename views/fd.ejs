            top: .05rem;
            font-size: .65rem;
            color: #C5A059;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .mf .ub {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 1px;
            background: #C5A059;
            transition: width .4s cubic-bezier(.23, 1, .32, 1);
        }

