            to {
                transform: translateX(-50%)
            }
        }

        /* FD card */
        .fd-card {
            border: 1px solid rgba(197, 160, 89, .12);
            background: rgba(13, 30, 56, 0.5);
            border-radius: 1.25rem;
            transition: all .35s ease-out;
            position: relative;
            overflow: hidden;
