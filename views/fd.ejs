        }

        /* View toggle */
        .vtab {
            padding: .4rem 1rem;
            border-radius: .5rem;
            font-size: .75rem;
            font-weight: 500;
            cursor: pointer;
            transition: background .2s, color .2s;
            color: rgba(240, 244, 248, .4);
        }

        .vtab.active {
            background: rgba(197, 160, 89, .15);
            color: #C5A059;
        }

        /* ── FD Calculator ── */
        .calc-slider {
            -webkit-appearance: none;
            appearance: none;
            width: 100%;
            height: 4px;
            background: rgba(197, 160, 89, .2);
            border-radius: 2px;
            outline: none;
            cursor: pointer;
        }

        .calc-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: var(--gold);
            border: 3px solid var(--navy2);
            cursor: pointer;
            box-shadow: 0 0 0 4px rgba(197, 160, 89, .2);
        }

        .calc-slider::-moz-range-thumb {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: var(--gold);
            border: 3px solid var(--navy2);
            cursor: pointer;
        }

        /* Donut chart */
        .donut-ring {
            transform: rotate(-90deg);
            transform-origin: 50% 50%;
        }

        .donut-principal {
            stroke: rgba(197, 160, 89, .25);
            transition: stroke-dasharray .7s cubic-bezier(.23, 1, .32, 1);
        }

        .donut-interest {
            stroke: var(--gold);
            transition: stroke-dasharray .7s cubic-bezier(.23, 1, .32, 1), stroke-dashoffset .7s cubic-bezier(.23, 1, .32, 1);
        }

        /* Modal */
        #invest-modal {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(8, 21, 42, .87);
            backdrop-filter: blur(12px);
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        #invest-modal.open {
            display: flex;
        }

        .modal-box {
            background: linear-gradient(145deg, #0D1E38, #08152A);
            border: 1px solid rgba(197, 160, 89, .25);
            border-radius: 1.5rem;
            padding: 2rem;
            max-width: 460px;
            width: 100%;
            position: relative;
            max-height: 90vh;
            overflow-y: auto;
        }

        @keyframes mIn {
            from {
                opacity: 0;
                transform: scale(.93) translateY(20px)
            }

            to {
                opacity: 1;
                transform: none
            }
        }

        .modal-box {
            animation: mIn .35s cubic-bezier(.23, 1, .32, 1) both;
        }

        /* Form fields */
        .mf {
            position: relative;
            margin-bottom: 1.6rem;
        }

        .mf input,
        .mf select,
        .mf textarea {
            width: 100%;
            background: transparent;
            border: none;
            border-bottom: 1px solid rgba(197, 160, 89, .3);
            padding: 1.3rem 0 .4rem;
            font-size: .85rem;
            color: #F0F4F8;
            outline: none;
            transition: border-color .3s;
            font-family: "DM Sans", sans-serif;
            resize: none;
        }

        .mf select option {
            background: #0D1E38;
        }

        .mf input:focus,
        .mf select:focus {
            border-bottom-color: #C5A059;
        }

        .mf label {
            position: absolute;
            top: 1.2rem;
            left: 0;
            font-size: .8rem;
            color: rgba(240, 244, 248, .35);
            pointer-events: none;
            transition: top .25s, font-size .25s, color .25s;
        }

