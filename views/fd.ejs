        }

        .sort-sel:focus {
            border-color: rgba(197, 160, 89, .5);
        }

        .sort-sel option {
            background: #0D1E38;
        }

        /* Rate bar */
        .rate-bar-bg {
            height: 4px;
            background: rgba(197, 160, 89, .1);
            border-radius: 2px;
            overflow: hidden;
        }

        .rate-bar-fill {
            height: 100%;
            border-radius: 2px;
            background: linear-gradient(90deg, var(--gold), var(--gold2));
            transition: width .8s cubic-bezier(.23, 1, .32, 1);
        }

        /* Table */
        .tbl-row {
            border-bottom: 1px solid rgba(197, 160, 89, .06);
            transition: background .2s;
        }

        .tbl-row:hover {
            background: rgba(197, 160, 89, .04);
        }

        .tbl-row:last-child {
