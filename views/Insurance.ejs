    <!-- ════════════════════ SCRIPTS ════════════════════ -->
    <script>
        /* ── Plans Data ── */
        const plans = JSON.parse(document.getElementById('plans-data').textContent);

        /* ── FAQs ── */
        const faqs = [
            { q: 'What is the difference between Term and ULIP insurance?', a: 'A Term plan provides pure life cover — if you pass away during the policy term, your nominee receives the sum assured. It has no maturity value. A ULIP (Unit Linked Insurance Plan) combines life cover with investment in market-linked funds, meaning you can accumulate wealth over the policy term while remaining insured.' },
            { q: 'How much life cover do I actually need?', a: 'A common rule of thumb is 10–15× your annual income. However, the ideal amount depends on your liabilities (home loan, business debt), dependant count, existing assets and future goals like children\'s education. Our advisors run a detailed Human Life Value (HLV) calculation for every client.' },
            { q: 'Is health insurance really necessary if my employer provides cover?', a: 'Employer-provided cover is typically ₹3–5 Lakh per year, covers only active employment, and ceases when you change jobs. A personal health policy ensures continuity, typically ₹10–50 Lakh in coverage, no co-pay, and is indexed to medical inflation through no-claim bonuses.' },
            { q: 'Can I claim tax benefits on insurance premiums?', a: 'Yes. Life insurance premiums qualify under Section 80C (up to ₹1.5 Lakh per year). Health insurance premiums qualify under Section 80D — up to ₹25,000 for self and family (₹50,000 if a parent is a senior citizen). Maturity proceeds of life policies are tax-free under Section 10(10D) subject to conditions.' },
            { q: 'What happens if I miss an insurance premium payment?', a: 'Most insurers offer a 15–30 day grace period. Missing beyond the grace period lapses the policy, which means the cover ceases. Some policies have revival options within 2 years. Term plans lapse immediately after grace; ULIPs have built-in fund value protection. AKMAY sends premium reminders for all clients.' },
            { q: 'What is a "free look" period for an insurance policy?', a: 'IRDAI mandates a 15–30 day free look period during which you can review any new policy and return it for a full premium refund if unsatisfied — no questions asked. AKMAY always advises clients to use this window to fully understand their policy documents.' },
        ];

        /* ── Render helpers ── */
        function chipClass(type) { const m = { Term: 'chip-term', Health: 'chip-health', ULIP: 'chip-ulip', Endowment: 'chip-endow' }; return m[type] || 'chip-term'; }

        function renderGrid(list) {
            const c = document.getElementById('grid-view'); c.innerHTML = '';
            list.forEach((p, i) => {
                const card = document.createElement('article');
                card.className = `ins-card p-5 flex flex-col${p.hot ? ' featured-card' : ''}`;
                card.style.animation = `fadeUp .5s cubic-bezier(.23,1,.32,1) ${i * 0.04}s both`;
                card.innerHTML = `
      <!-- Clean Header -->
      <div class="flex items-start justify-between mb-4 pb-4 border-b border-white/8">
        <div class="flex items-center gap-2.5">
          ${p.imglink ? `<img src="${p.imglink}" class="w-9 h-9 rounded-lg object-cover" alt="${p.name}">` : `<div class="w-9 h-9 rounded-lg bg-brand-gold/10 flex items-center justify-center text-brand-gold font-bold text-xs">${p.name.substring(0, 2).toUpperCase()}</div>`}
          <div class="min-w-0">
            <p class="text-white/50 text-xs leading-none">${p.insurer}</p>
          </div>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
          <span class="${chipClass(p.type)} px-2 py-0.5 rounded text-xs font-semibold">${p.type}</span>
          ${p.hot ? '<span class="bg-emerald-500/20 text-emerald-300 px-2 py-0.5 rounded text-xs font-bold">HOT</span>' : ''}
        </div>
      </div>

      <!-- Product Info -->
      <h3 class="text-white font-semibold text-base mb-2">${p.name}</h3>
      <p class="text-white/50 text-sm mb-4 leading-snug">${p.desc}</p>

      <!-- Key Stats -->
      <div class="space-y-3 mb-5">
        <div class="flex justify-between items-baseline">
          <span class="text-white/40 text-xs">Sum Insured</span>
          <span class="text-white font-bold text-sm">${p.cover}</span>
        </div>
        <div class="flex justify-between items-baseline">
          <span class="text-white/40 text-xs">Starting Premium</span>
          <span class="text-brand-gold font-bold text-sm">${p.premium}</span>
        </div>
        <div class="flex justify-between items-baseline">
          <span class="text-white/40 text-xs">Settlement Ratio</span>
          <span class="text-emerald-400 font-semibold text-sm">${p.claim}</span>
        </div>
      </div>

      <!-- Features -->
      ${(p.features || []).length > 0 ? `
      <div class="mb-5 pb-5 border-t border-white/8 pt-4">
        <div class="flex flex-wrap gap-1.5">
          ${(p.features || []).map(f => `<span class="text-xs text-white/50 px-2 py-1 rounded border border-white/10">${f}</span>`).join('')}
        </div>
      </div>
      ` : `<div class="mb-5"></div>`}

      <!-- CTA -->
      <button onclick="openModal(${p.id})" class="btn-gold w-full py-2.5 rounded-lg text-sm font-semibold">
        Get Advisory
      </button>
    `;
                c.appendChild(card);
            });
        }

        function renderTable(list) {
            const b = document.getElementById('table-body'); b.innerHTML = '';
            list.forEach(p => {
                const row = document.createElement('div');
                row.className = 'tbl-row grid items-center px-5 py-3.5';
                row.style.gridTemplateColumns = '2fr 1fr 1fr 1fr 1fr 1fr';
                row.innerHTML = `
      <div class="flex items-center gap-3">
        ${p.imglink ? `<img src="${p.imglink}" class="w-8 h-8 rounded-lg object-cover border border-white/5" alt="${p.name}">` : `<div class="w-8 h-8 rounded-lg bg-brand-gold/10 flex items-center justify-center text-brand-gold text-[10px] font-bold">${p.name.substring(0, 2).toUpperCase()}</div>`}
        <div>
          <p class="text-white text-sm font-medium">${p.name}</p>
          <p class="text-white/35 text-xs">${p.insurer}</p>
        </div>
      </div>
      <div class="text-right"><span class="text-xs ${chipClass(p.type)} px-2 py-0.5 rounded-full">${p.type}</span></div>
      <div class="text-right text-brand-muted text-sm">${p.cover}</div>
      <div class="text-right text-brand-gold font-semibold text-sm">${p.premium}</div>
      <div class="text-right text-emerald-400 text-sm">${p.claim}</div>
      <div class="text-right"><button onclick="openModal(${p.id})" class="btn-gold px-3 py-1.5 rounded-lg text-xs">Advise</button></div>
    `;
                b.appendChild(row);
            });
        }

        let curType = 'all', curSort = 'default', curSearch = '', curView = 'grid';
        function getFiltered() {
            let l = [...plans];
            if (curType !== 'all') l = l.filter(p => p.type === curType);
            if (curSearch) l = l.filter(p => p.name.toLowerCase().includes(curSearch) || p.insurer.toLowerCase().includes(curSearch));
            if (curSort === 'az') l.sort((a, b) => a.name.localeCompare(b.name));
            else if (curSort === 'premium-low') l.sort((a, b) => a.premiumNum - b.premiumNum);
            else if (curSort === 'cover-high') l.sort((a, b) => b.coverNum - a.coverNum);
            else l.sort((a, b) => (b.hot ? 1 : 0) - (a.hot ? 1 : 0));
            return l;
        }
        function renderAll() {
            const l = getFiltered();
            document.getElementById('ins-count').textContent = l.length;
            const em = document.getElementById('empty-state');
            if (!l.length) { em.classList.remove('hidden'); document.getElementById('grid-view').innerHTML = ''; document.getElementById('table-body').innerHTML = ''; return; }
            em.classList.add('hidden');
            if (curView === 'grid') renderGrid(l); else renderTable(l);
        }
        function resetFilters() { curType = 'all'; curSearch = ''; curSort = 'default'; document.getElementById('ins-search').value = ''; document.getElementById('ins-sort').value = 'default'; document.querySelectorAll('.ptab').forEach(p => p.classList.toggle('active', p.dataset.type === 'all')); renderAll(); }

        document.getElementById('ins-search').addEventListener('input', e => { curSearch = e.target.value.toLowerCase().trim(); renderAll(); });
        document.getElementById('ins-sort').addEventListener('change', e => { curSort = e.target.value; renderAll(); });
        document.querySelectorAll('.ptab').forEach(btn => btn.addEventListener('click', () => { curType = btn.dataset.type; document.querySelectorAll('.ptab').forEach(p => p.classList.remove('active')); btn.classList.add('active'); renderAll(); }));
        document.getElementById('vg').addEventListener('click', () => { curView = 'grid'; document.getElementById('grid-view').classList.remove('hidden'); document.getElementById('table-view').classList.add('hidden'); document.getElementById('vg').classList.add('active'); document.getElementById('vt').classList.remove('active'); renderAll(); });
        document.getElementById('vt').addEventListener('click', () => { curView = 'table'; document.getElementById('table-view').classList.remove('hidden'); document.getElementById('grid-view').classList.add('hidden'); document.getElementById('vt').classList.add('active'); document.getElementById('vg').classList.remove('active'); renderAll(); });

        /* ── Quiz logic ── */
        let quizStep = 1, quizAnswers = {};
        const maxStep = 4;
        const recMap = {
            protect: { result: 'Based on your goal of protecting your family, we recommend a <strong>Term Life Insurance</strong> plan with a sum assured of at least 15× your annual income.', tags: ['Term Life', 'Critical Illness Rider'] },
            health: { result: 'Your priority for medical coverage makes a <strong>comprehensive Health Insurance</strong> plan essential — ideally a family floater with ₹25–50 Lakh cover and zero co-pay.', tags: ['Health Insurance', 'Family Floater'] },
            grow: { result: 'To grow wealth while staying protected, a <strong>ULIP Plan</strong> offers the best of both worlds — market-linked returns plus life cover. Horizon of 10+ years is ideal.', tags: ['ULIP', 'Market-Linked Returns'] },
            legacy: { result: 'For long-term legacy creation, we recommend an <strong>Endowment or Child Plan</strong> — providing guaranteed returns, life cover and a structured corpus at maturity.', tags: ['Endowment Plan', 'Child Plan'] },
        };

        function selectOpt(el, qid) {
            el.closest('.space-y-3').querySelectorAll('.qopt').forEach(o => o.classList.remove('selected'));
            el.classList.add('selected');
            quizAnswers[qid] = el.dataset.val;
            const btn = document.getElementById('quiz-next');
            btn.disabled = false; btn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
        function quizNext() {
            if (!quizAnswers['q' + quizStep]) return;
            if (quizStep < maxStep) {
                document.getElementById('qs' + quizStep).classList.remove('active');
                quizStep++;
                document.getElementById('qs' + quizStep).classList.add('active');
                document.getElementById('quiz-prog').style.width = (quizStep / maxStep * 100) + '%';
                document.getElementById('quiz-step-label').textContent = quizStep + ' / ' + maxStep;
                document.getElementById('quiz-back').classList.remove('invisible');
                const hasAns = !!quizAnswers['q' + quizStep];
                const btn = document.getElementById('quiz-next');
                btn.disabled = !hasAns; btn.classList.toggle('opacity-50', !hasAns); btn.classList.toggle('cursor-not-allowed', !hasAns);
                if (quizStep === maxStep) { btn.textContent = 'See Results'; btn.innerHTML = 'See Results <span class="material-symbols-outlined text-sm">arrow_forward</span>'; }
            } else {
                document.getElementById('qs' + quizStep).classList.remove('active');
                const rec = recMap[quizAnswers['q1']] || recMap['protect'];
                document.getElementById('quiz-result-text').innerHTML = rec.result;
                const tagsEl = document.getElementById('quiz-result-tags');
                tagsEl.innerHTML = rec.tags.map(t => `<span class="text-xs text-brand-gold border border-brand-gold/30 bg-brand-gold/8 px-3 py-1 rounded-full">${t}</span>`).join('');
                document.getElementById('qs-result').classList.add('active');
                document.getElementById('quiz-nav').classList.add('hidden');
                document.getElementById('quiz-prog').style.width = '100%';
                document.getElementById('quiz-step-label').textContent = 'Done!';
            }
        }
        function quizBack() {
            if (quizStep <= 1) return;
            document.getElementById('qs' + quizStep).classList.remove('active');
            quizStep--;
            document.getElementById('qs' + quizStep).classList.add('active');
            document.getElementById('quiz-prog').style.width = (quizStep / maxStep * 100) + '%';
            document.getElementById('quiz-step-label').textContent = quizStep + ' / ' + maxStep;
            if (quizStep === 1) document.getElementById('quiz-back').classList.add('invisible');
            const btn = document.getElementById('quiz-next');
            const hasAns = !!quizAnswers['q' + quizStep];
            btn.disabled = !hasAns; btn.classList.toggle('opacity-50', !hasAns); btn.classList.toggle('cursor-not-allowed', !hasAns);
            btn.innerHTML = 'Next <span class="material-symbols-outlined text-sm">arrow_forward</span>';
        }
        function resetQuiz() {
            quizStep = 1; quizAnswers = {};
            document.querySelectorAll('.quiz-step').forEach(s => s.classList.remove('active'));
            document.getElementById('qs1').classList.add('active');
            document.querySelectorAll('.qopt').forEach(o => o.classList.remove('selected'));
            document.getElementById('quiz-prog').style.width = '25%';
            document.getElementById('quiz-step-label').textContent = '1 / 4';
            document.getElementById('quiz-back').classList.add('invisible');
            document.getElementById('quiz-nav').classList.remove('hidden');
            const btn = document.getElementById('quiz-next'); btn.disabled = true; btn.classList.add('opacity-50', 'cursor-not-allowed');
            btn.innerHTML = 'Next <span class="material-symbols-outlined text-sm">arrow_forward</span>';
        }

        /* ── FAQs render ── */
        const fc = document.getElementById('faq-container');
        faqs.forEach((f, i) => {
            const el = document.createElement('details');
            el.className = 'faq-item reveal group'; el.style.transitionDelay = `${i * 0.04}s`;
            el.innerHTML = `<summary class="flex items-center justify-between p-5 cursor-pointer list-none gap-3"><span class="text-white font-medium text-sm">${f.q}</span><span class="faq-icon material-symbols-outlined text-brand-gold flex-shrink-0">add</span></summary><div class="px-5 pb-5 text-brand-muted text-sm leading-relaxed">${f.a}</div>`;
            fc.appendChild(el);
        });

        /* ── Modal ── */
        function openModal(id) {
            const banner = document.getElementById('modal-plan-banner');
            if (id) {
                const p = plans.find(x => x.id === id);
                if (p) {
                    document.getElementById('modal-plan-name').textContent = p.name;
                    document.getElementById('modal-plan-meta').textContent = `${p.type} · ${p.insurer} · ${p.premium}`;
                    banner.classList.remove('hidden'); banner.classList.add('flex');
                }
            } else { banner.classList.add('hidden'); banner.classList.remove('flex'); }
            document.getElementById('enquiry-modal').classList.add('open');
            document.body.style.overflow = 'hidden';
        }
        function closeModal() { document.getElementById('enquiry-modal').classList.remove('open'); document.body.style.overflow = ''; }
        document.getElementById('enquiry-modal').addEventListener('click', e => { if (e.target === document.getElementById('enquiry-modal')) closeModal(); });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

        document.getElementById('modal-form').addEventListener('submit', async e => {
            e.preventDefault();
            const txt = document.getElementById('m-txt'), spin = document.getElementById('m-spin');
            txt.textContent = 'Sending…'; spin.classList.remove('hidden');
            await new Promise(r => setTimeout(r, 1700));
            spin.classList.add('hidden'); txt.textContent = 'Get Free Advisory';
            closeModal(); document.getElementById('modal-form').reset();
            ['m-type', 'm-budget'].forEach(id => document.getElementById(id).closest('.mf').classList.remove('filled'));
            document.getElementById('success-overlay').classList.add('show');
        });
        ['m-type', 'm-budget'].forEach(id => {
            document.getElementById(id).addEventListener('change', function () { this.closest('.mf').classList.toggle('filled', !!this.value); });
        });

        /* ── Scroll behaviours ── */
        const nav = document.getElementById('topnav'), fc2 = document.getElementById('float-cta');
        window.addEventListener('scroll', () => { nav.classList.toggle('scrolled', window.scrollY > 60); fc2.classList.toggle('show', window.scrollY > 400); });

        /* ── Reveal ── */
        const rvio = new IntersectionObserver(entries => { entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('up'); rvio.unobserve(e.target); } }); }, { threshold: .1 });
        document.querySelectorAll('.reveal,.reveal-l,.reveal-r,.faq-item').forEach(el => rvio.observe(el));

        /* ── Init ── */
        renderAll();

        /* ── Newsletter Subscription ── */
        const subscribeBtn = document.getElementById('subscribe-btn');
        const emailInput = document.getElementById('subscriber-email');

        if (subscribeBtn && emailInput) {
            subscribeBtn.addEventListener('click', async () => {
                const email = emailInput.value.trim();
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                if (!email || !emailRegex.test(email)) {
                    alert('Please enter a valid email address.');
                    return;
                }

                try {
                    subscribeBtn.disabled = true;
                    subscribeBtn.textContent = 'Subscribing...';

                    const response = await fetch('/subscribe', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({ email })
                    });

                    const result = await response.json();

                    if (response.ok) {
                        alert(result.message);
                        emailInput.value = '';
                    } else {
                        alert(result.message || "Something went wrong. Please try again.");
                    }
                } catch (error) {
                    console.error("Subscription Error:", error);
                    alert("Failed to connect to the server. Please check your connection.");
                } finally {
                    subscribeBtn.disabled = false;
                    subscribeBtn.textContent = 'Subscribe';
                }
            });
        }
    </script>
</body>

</html>