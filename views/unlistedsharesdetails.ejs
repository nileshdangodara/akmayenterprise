    <script>
        /* ── Load company from backend ── */

        const co = JSON.parse(document.getElementById('unlisted-data').textContent);
        const sectorColors = { Finance: '#3B82F6', Tech: '#8B5CF6', Healthcare: '#10B981', FMCG: '#F59E0B', Infra: '#6B7280', Energy: '#EF4444', Metals: '#A78BFA', Defence: '#FB923C' };
        const sectorBg = { Finance: 'rgba(59,130,246,.18)', Tech: 'rgba(139,92,246,.18)', Healthcare: 'rgba(16,185,129,.18)', FMCG: 'rgba(245,158,11,.18)', Infra: 'rgba(107,114,128,.18)', Energy: 'rgba(239,68,68,.18)', Metals: 'rgba(167,139,250,.18)', Defence: 'rgba(251,146,60,.18)' };

        function fmtINR(n) { if (!n && n !== 0) return '—'; return '₹' + Math.round(n).toLocaleString('en-IN'); }

        /* ── Inject page meta ── */
        document.title = `${co.name} Unlisted Share Price | Buy & Sell | AKMAY Enterprise LLP`;
        document.getElementById('page-desc').content = `Buy and sell ${co.name} unlisted shares at best prices through AKMAY Enterprise LLP. Current price ₹${co.price}. SEBI-compliant, Demat-secured.`;
        document.getElementById('bc-name').textContent = co.name;

        /* ── Hero ── */
        const av = document.getElementById('hero-avatar');
        if (co.imglink) {
            av.innerHTML = `<img src="${co.imglink}" class="w-full h-full object-cover" alt="${co.name}">`;
            av.style.background = 'transparent';
        } else {
            av.textContent = co.short;
            av.style.background = sectorBg[co.sector] || 'rgba(197,160,89,.15)';
            av.style.color = sectorColors[co.sector] || '#C5A059';
        }
        document.getElementById('hero-name').textContent = co.name;
        document.getElementById('hero-price').textContent = fmtINR(co.price);
        document.getElementById('hero-52').textContent = `${fmtINR(co.high52)} / ${fmtINR(co.low52)}`;
        document.getElementById('hero-mcap').textContent = co.mcap;
        document.getElementById('hero-isin').textContent = `ISIN: ${co.isin}`;
        document.getElementById('hero-sector-tag').textContent = co.sector;
        const cb = document.getElementById('hero-chg-badge');
        if (co.change === null) { cb.textContent = 'N/A'; cb.style.cssText = 'background:rgba(197,160,89,.12);border:1px solid rgba(197,160,89,.3);color:#C5A059;'; }
        else if (co.change > 0) { cb.textContent = `▲ +${co.change}%`; cb.style.cssText = 'background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.25);color:#34D399;'; }
        else { cb.textContent = `▼ ${co.change}%`; cb.style.cssText = 'background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.25);color:#F87171;'; }

        /* ── Side card ── */
        document.getElementById('side-price').textContent = fmtINR(co.price);
        document.getElementById('lot-label').textContent = co.lot.toLocaleString('en-IN');
        function calcBSValues() {
            const lots = parseInt(document.getElementById('qty-input').value) || 1;
            const shares = lots * co.lot;
            const val = shares * co.price;
            document.getElementById('calc-shares').textContent = shares.toLocaleString('en-IN') + ' shares';
            document.getElementById('calc-value').textContent = fmtINR(val);
        }
        document.getElementById('qty-input').addEventListener('input', calcBSValues);
        calcBSValues();

        /* ── Quick facts ── */
        const qf = document.getElementById('quick-facts');
        [['Lot Size', co.lot.toLocaleString('en-IN') + ' shares'], ['Face Value', `₹${co.faceValue}`], ['ISIN', co.isin], ['PAN', co.pan], ['Depository', co.depository], ['RTA', co.rta], ['Market Cap', co.mcap]].forEach(([k, v]) => {
            const d = document.createElement('div'); d.className = 'flex justify-between text-xs gap-2';
            d.innerHTML = `<span class="text-white/35">${k}</span><span class="text-white font-medium text-right">${v}</span>`;
            qf.appendChild(d);
        });

        /* ── About ── */
        const at = document.getElementById('about-text');
        (co.about || []).forEach(p => { const el = document.createElement('p'); el.textContent = p; at.appendChild(el); });
        document.getElementById('products-text').textContent = co.products || '';

        /* ── Fundamentals ── */
        const fg = document.getElementById('fund-grid');
        [['Current Price', fmtINR(co.price)], ['52 Week High', fmtINR(co.high52)], ['52 Week Low', fmtINR(co.low52)], ['Market Cap', co.mcap], ['P/E Ratio', co.pe], ['P/B Ratio', co.pb], ['ROE', co.roe], ['Debt to Equity', co.d2e], ['Book Value', `₹${co.bookValue}`], ['Face Value', `₹${co.faceValue}`], ['Total Shares', co.totalShares], ['ISIN', co.isin], ['PAN Number', co.pan], ['CIN', co.cin], ['Depository', co.depository], ['RTA', co.rta]].forEach(([k, v]) => {
            const d = document.createElement('div'); d.className = 'fund-cell';
            d.innerHTML = `<span class="text-white/45 text-sm">${k}</span><span class="text-white font-semibold text-sm text-right">${v || 'N/A'}</span>`;
            fg.appendChild(d);
        });

        /* ── Financials ── */
        function buildFinRow(data, cols) {
            const row = document.createElement('div');
            row.className = 'fin-row text-sm';
            row.innerHTML = cols.map((v, i) => `<span class="${i === 0 ? 'text-white/60' : 'text-right font-semibold ' + (v < 0 ? 'text-red-400' : v > 0 ? 'text-white' : 'text-brand-muted')}">${i === 0 ? v : (v != null ? v.toLocaleString('en-IN') : '—')}</span>`).join('');
            return row;
        }
        const qb = document.getElementById('fin-q-body');
        (co.quarterly || []).forEach(r => qb.appendChild(buildFinRow(r, [r.q, r.rev, r.ebitda, r.pat])));
        const yb = document.getElementById('fin-y-body');
        (co.yearly || []).forEach(r => yb.appendChild(buildFinRow(r, [r.y, r.rev, r.ebitda, r.pat])));

        function showFin(t) {
            document.getElementById('fin-quarterly').classList.toggle('hidden', t !== 'q');
            document.getElementById('fin-yearly').classList.toggle('hidden', t !== 'y');
            document.getElementById('fin-q-btn').classList.toggle('active', t === 'q');
            document.getElementById('fin-y-btn').classList.toggle('active', t === 'y');
        }

        /* ── FAQ ── */
        const fc = document.getElementById('faq-container');
        (co.faqs || []).forEach(f => {
            const el = document.createElement('details'); el.className = 'faq-item group';
            el.innerHTML = `<summary class="flex items-center justify-between p-5 cursor-pointer list-none gap-3"><span class="text-white font-medium text-sm">${f.q}</span><span class="faq-icon material-symbols-outlined text-brand-gold flex-shrink-0">add</span></summary><div class="px-5 pb-5 text-brand-muted text-sm leading-relaxed">${f.a}</div>`;
            fc.appendChild(el);
        });

        /* ── Chart ── */
        let chart, currentPeriod = '6m';

        function generatePriceData(period) {
            const basePrice = co.price; const low = co.low52; const high = co.high52;
            const points = {
                '1m': { count: 30, start: basePrice * (co.change > 0 ? .92 : .98) },
                '6m': { count: 26, start: low * 1.05 },
                '1y': { count: 52, start: low },
                '3y': { count: 36, start: low * .85 },
                'max': { count: 60, start: low * .7 },
            }[period] || { count: 26, start: low * 1.05 };
            const labels = [], data = [];
            for (let i = 0; i < points.count; i++) {
                const progress = i / (points.count - 1);
                const trend = points.start + (basePrice - points.start) * Math.pow(progress, .7);
                const noise = (Math.random() - .5) * (high - low) * .12;
                data.push(Math.max(low * .9, Math.min(high * 1.05, trend + noise)));
                if (period === 'max') labels.push(2020 + Math.floor(i / 12) + '-' + String((i % 12) + 1).padStart(2, '0'));
                else if (period === '3y') labels.push('M' + (i + 1));
                else if (period === '1y') labels.push('W' + (i + 1));
                else labels.push(i + 1);
            }
            return { labels, data };
        }

        function buildChart(period) {
            const { labels, data } = generatePriceData(period);
            const isUp = data[data.length - 1] >= data[0];
            const color = isUp ? '#34D399' : '#F87171';
            const ctx = document.getElementById('price-chart').getContext('2d');
            const grad = ctx.createLinearGradient(0, 0, 0, 220);
            grad.addColorStop(0, isUp ? 'rgba(52,211,153,.2)' : 'rgba(248,113,113,.2)');
            grad.addColorStop(1, 'rgba(8,21,42,0)');
            if (chart) chart.destroy();
            chart = new Chart(ctx, {
                type: 'line',
                data: { labels, datasets: [{ data, borderColor: color, backgroundColor: grad, borderWidth: 2, pointRadius: 0, tension: .4, fill: true }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => `₹${Math.round(ctx.raw).toLocaleString('en-IN')}` }, backgroundColor: 'rgba(13,30,56,.95)', borderColor: 'rgba(197,160,89,.3)', borderWidth: 1, titleColor: 'rgba(240,244,248,.6)', bodyColor: '#C5A059', bodyFont: { family: '"DM Sans"', size: 13, weight: 'bold' } } }, scales: { x: { display: false }, y: { display: true, grid: { color: 'rgba(197,160,89,.05)' }, ticks: { color: 'rgba(240,244,248,.3)', font: { size: 10 }, callback: v => `₹${Math.round(v).toLocaleString('en-IN')}` }, border: { display: false } } } },
            });
        }

        document.querySelectorAll('.ptab').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('#period-tabs .ptab').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentPeriod = btn.dataset.p;
                buildChart(currentPeriod);
            });
        });
        buildChart('6m');

        /* ── Buy/Sell toggle ── */
        let bsMode = 'buy';
        function setBS(mode) {
            bsMode = mode;
            document.getElementById('bs-buy').className = 'bs-tab ' + (mode === 'buy' ? 'buy-active' : 'inactive');
            document.getElementById('bs-sell').className = 'bs-tab ' + (mode === 'sell' ? 'sell-active' : 'inactive');
            document.getElementById('bs-btn-txt').textContent = mode === 'buy' ? 'Submit Buy Request' : 'Submit Sell Request';
        }

        /* ── Detail tabs ── */
        document.querySelectorAll('.dtab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.dtab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.dtab-section').forEach(s => s.classList.remove('active'));
                tab.classList.add('active');
                document.getElementById('dt-' + tab.dataset.dt).classList.add('active');
            });
        });

        /* ── Form submissions ── */
        async function submitBS() {
            const name = document.getElementById('bs-name').value.trim();
            const contact = document.getElementById('bs-contact').value.trim();
            const msg = document.getElementById('bs-msg').value.trim();
            const qty = document.getElementById('qty-input').value.trim();

            if (!name || !contact) { alert('Please enter your name and contact detail.'); return; }

            const btnTxt = document.getElementById('bs-btn-txt');
            const origTxt = btnTxt.textContent;
            btnTxt.textContent = 'Sending...';

            try {
                const payload = {
                    formSource: 'Unlisted Shares Transaction',
                    transactionType: bsMode,
                    company: co.name,
                    quantityInLots: qty,
                    fullName: name,
                    contactDetails: contact,
                    message: msg
                };
                const res = await fetch('/send-email', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (!res.ok) throw new Error('Failed');

                document.getElementById('success-title').textContent = bsMode === 'buy' ? 'Buy Request Sent' : 'Sell Request Sent';
                document.getElementById('success-msg').textContent = `An AKMAY advisor will contact you within one business day to process your ${bsMode} request for ${co.name}.`;
                document.getElementById('success-overlay').classList.add('show');
                document.getElementById('bs-name').value = '';
                document.getElementById('bs-contact').value = '';
                document.getElementById('bs-msg').value = '';
                document.getElementById('qty-input').value = '1';
                calcBSValues();
            } catch (err) {
                alert('An error occurred. Please try again.');
            } finally {
                btnTxt.textContent = origTxt;
            }
        }


        /* ── Scroll & Reveal ── */
        const nav = document.getElementById('topnav'), fc2 = document.getElementById('float-cta');
        window.addEventListener('scroll', () => { nav.classList.toggle('scrolled', window.scrollY > 60); fc2.classList.toggle('show', window.scrollY > 400); });
        const rvio = new IntersectionObserver(e => { e.forEach(x => { if (x.isIntersecting) { x.target.classList.add('up'); rvio.unobserve(x.target); } }); }, { threshold: .1 });
        document.querySelectorAll('.reveal').forEach(el => rvio.observe(el));

        /* ── Newsletter Subscription ── */
        const subscribeBtn = document.getElementById('subscribe-btn');
        const emailInput = document.getElementById('subscriber-email');

        if (subscribeBtn && emailInput) {
            subscribeBtn.addEventListener('click', async () => {
                const email = emailInput.value.trim();
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                if (!email || !emailRegex.test(email)) {
                    alert('Please enter a valid email address.');
                    return;
                }

                try {
                    subscribeBtn.disabled = true;
                    subscribeBtn.textContent = 'Subscribing...';

                    const response = await fetch('/subscribe', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({ email })
                    });

                    const result = await response.json();

                    if (response.ok) {
                        alert(result.message);
                        emailInput.value = '';
                    } else {
                        alert(result.message || "Something went wrong. Please try again.");
                    }
                } catch (error) {
                    console.error("Subscription Error:", error);
                    alert("Failed to connect to the server. Please check your connection.");
                } finally {
                    subscribeBtn.disabled = false;
                    subscribeBtn.textContent = 'Subscribe';
                }
            });
        }
    </script>
</body>

</html>