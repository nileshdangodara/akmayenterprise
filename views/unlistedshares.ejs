    <script id="shares-data" type="application/json">
        <%- JSON.stringify(shares) %>
    </script>
    <script>
        /* ── Data ── */
        const shares = JSON.parse(document.getElementById('shares-data').textContent);

        const sectorColors = { Finance: '#3B82F6', Tech: '#8B5CF6', Healthcare: '#10B981', FMCG: '#F59E0B', Infra: '#6B7280', Energy: '#EF4444', Metals: '#A78BFA', Defence: '#FB923C' };
        const sectorBg = { Finance: 'rgba(59,130,246,.18)', Tech: 'rgba(139,92,246,.18)', Healthcare: 'rgba(16,185,129,.18)', FMCG: 'rgba(245,158,11,.18)', Infra: 'rgba(107,114,128,.18)', Energy: 'rgba(239,68,68,.18)', Metals: 'rgba(167,139,250,.18)', Defence: 'rgba(251,146,60,.18)' };

        function chgBadge(c) {
            if (c === null) return `<span class="badge-flat text-xs px-2 py-0.5 rounded-full">N/A</span>`;
            if (c > 0) return `<span class="badge-up text-xs px-2 py-0.5 rounded-full">▲ +${c}%</span>`;
            return `<span class="badge-down text-xs px-2 py-0.5 rounded-full">▼ ${c}%</span>`;
        }

        function sparkPath(change) {
            const pts = [[0, 40], [10, 38], [20, 35], [30, 36], [40, 33], [50, change > 0 ? 22 : 48], [60, change > 0 ? 18 : 52], [70, change > 0 ? 14 : 55], [80, change > 0 ? 10 : 58], [90, change > 0 ? 6 : 62], [100, change > 0 ? 2 : 65]];
            return 'M' + pts.map(p => p.join(',')).join(' L');
        }

        function renderGrid(list) {
            const c = document.getElementById('grid-view'); c.innerHTML = '';
            list.forEach((s, i) => {
                const card = document.createElement('a');
                card.href = `/unlisted-shares/${s.slug}`;
                card.className = 'share-card p-5 flex flex-col' + (s.featured ? ' border-brand-gold/28' : '');
                if (s.featured) card.style.background = 'linear-gradient(145deg,rgba(197,160,89,.08),rgba(197,160,89,.02))';
                card.style.animation = `fadeUp .5s cubic-bezier(.23,1,.32,1) ${i * 0.035}s both`;
                const chgColor = s.change === null ? '#C5A059' : s.change > 0 ? '#34D399' : '#F87171';
                card.innerHTML = `
      <div class="flex items-start justify-between mb-4">
        <div class="flex items-center gap-3">
          ${s.imglink ? `<img src="${s.imglink}" class="w-12 h-12 rounded-xl object-cover border border-white/10" alt="${s.name}">` : `<div class="co-avatar" style="background:${sectorBg[s.sector]};color:${sectorColors[s.sector]}">${s.short}</div>`}
          <div class="min-w-0">
            <h3 class="text-white font-semibold text-sm leading-tight line-clamp-2">${s.name}</h3>
            <span class="sector-tag">${s.sector}</span>
          </div>
        </div>
        ${s.featured ? '<span style="background:linear-gradient(135deg,#C5A059,#E5D5B7);color:#08152A;font-size:.5rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;padding:.2rem .5rem;border-radius:9999px;flex-shrink:0">TOP</span>' : ''}
      </div>
      <!-- Mini sparkline -->
      <svg viewBox="0 0 100 70" class="w-full h-10 mb-4" style="overflow:visible">
        <path d="${sparkPath(s.change)}" fill="none" stroke="${chgColor}" stroke-width="1.5" stroke-linecap="round" opacity=".6"/>
      </svg>
      <div class="grid grid-cols-2 gap-2 mb-3">
        <div class="bg-white/3 rounded-lg p-2.5">
          <p class="text-white/30 text-xs">Price</p>
          <p class="text-white font-bold text-sm">₹${s.price.toLocaleString('en-IN')}</p>
        </div>
        <div class="bg-white/3 rounded-lg p-2.5">
          <p class="text-white/30 text-xs">52w Chg</p>
          <div class="mt-0.5">${chgBadge(s.change)}</div>
        </div>
        <div class="bg-white/3 rounded-lg p-2.5">
          <p class="text-white/30 text-xs">52w H/L</p>
          <p class="text-white text-xs font-medium">₹${s.high52} / ₹${s.low52}</p>
        </div>
        <div class="bg-white/3 rounded-lg p-2.5">
          <p class="text-white/30 text-xs">Lot Size</p>
          <p class="text-white text-xs font-medium">${s.lot.toLocaleString('en-IN')}</p>
        </div>
      </div>
      <p class="text-brand-muted text-xs leading-relaxed mb-4 flex-1">${s.desc}</p>
      <div class="flex gap-2">
        <span class="flex-1 text-center py-2 rounded-lg text-xs font-bold border border-emerald-500/30 text-emerald-400 bg-emerald-500/8 cursor-pointer hover:bg-emerald-500/15 transition-colors">Buy</span>
        <span class="flex-1 text-center py-2 rounded-lg text-xs font-bold border border-red-400/30 text-red-400 bg-red-500/8 cursor-pointer hover:bg-red-500/15 transition-colors">Sell</span>
        <span class="px-3 py-2 rounded-lg text-xs font-bold btn-gold">Details →</span>
      </div>`;
                c.appendChild(card);
            });
        }

        function renderTable(list) {
            const b = document.getElementById('table-body'); b.innerHTML = '';
            list.forEach(s => {
                const row = document.createElement('a');
                row.href = `/unlisted-shares/${s.slug}`;
                row.className = 'tbl-row grid items-center px-5 py-3.5 block';
                row.style.gridTemplateColumns = '2.5fr 1fr 1.2fr 1fr 1fr 1fr';
                row.innerHTML = `
      <div class="flex items-center gap-3">
        ${s.imglink ? `<img src="${s.imglink}" class="w-9 h-9 rounded-lg object-cover border border-white/5" alt="${s.name}">` : `<div class="co-avatar w-9 h-9 text-xs rounded-lg" style="background:${sectorBg[s.sector]};color:${sectorColors[s.sector]};width:2.25rem;height:2.25rem;">${s.short}</div>`}
        <div><p class="text-white text-sm font-medium leading-tight">${s.name}</p><span class="sector-tag">${s.sector}</span></div>
      </div>
      <div class="text-right text-white font-bold text-sm">₹${s.price.toLocaleString('en-IN')}</div>
      <div class="text-right text-brand-muted text-xs">₹${s.high52} / ₹${s.low52}</div>
      <div class="text-right">${chgBadge(s.change)}</div>
      <div class="text-right text-brand-muted text-sm">${s.mcap}</div>
      <div class="text-right flex justify-end gap-1.5">
        <span class="px-2.5 py-1.5 rounded-lg text-xs font-bold border border-emerald-500/30 text-emerald-400 cursor-pointer">Buy</span>
        <span class="px-2.5 py-1.5 rounded-lg text-xs font-bold border border-red-400/30 text-red-400 cursor-pointer">Sell</span>
      </div>`;
                b.appendChild(row);
            });
        }

        let curSector = 'all', curSort = 'default', curSearch = '', curView = 'grid';
        function getFiltered() {
            let l = [...shares];
            if (curSector !== 'all') l = l.filter(s => s.sector === curSector);
            if (curSearch) l = l.filter(s => s.name.toLowerCase().includes(curSearch) || s.sector.toLowerCase().includes(curSearch));
            if (curSort === 'price-high') l.sort((a, b) => b.price - a.price);
            else if (curSort === 'price-low') l.sort((a, b) => a.price - b.price);
            else if (curSort === 'change-high') l.sort((a, b) => (b.change || 0) - (a.change || 0));
            else if (curSort === 'change-low') l.sort((a, b) => (a.change || 0) - (b.change || 0));
            else if (curSort === 'az') l.sort((a, b) => a.name.localeCompare(b.name));
            else l.sort((a, b) => (b.featured ? 1 : 0) - (a.featured ? 1 : 0));
            return l;
        }
        function render() {
            const l = getFiltered();
            document.getElementById('s-count').textContent = l.length;
            const em = document.getElementById('empty-state');
            if (!l.length) { em.style.display = 'block'; document.getElementById('grid-view').innerHTML = ''; document.getElementById('table-body').innerHTML = ''; return; }
            em.style.display = 'none';
            if (curView === 'grid') renderGrid(l); else renderTable(l);
        }
        function resetAll() { curSector = 'all'; curSearch = ''; curSort = 'default'; document.getElementById('s-search').value = ''; document.getElementById('s-sort').value = 'default'; document.querySelectorAll('.fpill').forEach(p => p.classList.toggle('active', p.dataset.f === 'all')); render(); }

        document.getElementById('s-search').addEventListener('input', e => { curSearch = e.target.value.toLowerCase().trim(); render(); });
        document.getElementById('s-sort').addEventListener('change', e => { curSort = e.target.value; render(); });
        document.querySelectorAll('.fpill').forEach(btn => btn.addEventListener('click', () => { curSector = btn.dataset.f; document.querySelectorAll('.fpill').forEach(p => p.classList.remove('active')); btn.classList.add('active'); render(); }));
        document.getElementById('vg').addEventListener('click', () => { curView = 'grid'; document.getElementById('grid-view').classList.remove('hidden'); document.getElementById('table-view').classList.add('hidden'); document.getElementById('vg').classList.add('active'); document.getElementById('vt').classList.remove('active'); render(); });
        document.getElementById('vt').addEventListener('click', () => { curView = 'table'; document.getElementById('table-view').classList.remove('hidden'); document.getElementById('grid-view').classList.add('hidden'); document.getElementById('vt').classList.add('active'); document.getElementById('vg').classList.remove('active'); render(); });

        const nav = document.getElementById('topnav'), fc = document.getElementById('float-cta');
        window.addEventListener('scroll', () => { nav.classList.toggle('scrolled', window.scrollY > 60); fc.classList.toggle('show', window.scrollY > 500); });
        const rvio = new IntersectionObserver(e => { e.forEach(x => { if (x.isIntersecting) { x.target.classList.add('up'); rvio.unobserve(x.target); } }); }, { threshold: .1 });
        document.querySelectorAll('.reveal').forEach(el => rvio.observe(el));
        render();

        /* ── Newsletter Subscription ── */
        const subscribeBtn = document.getElementById('subscribe-btn');
        const emailInput = document.getElementById('subscriber-email');

        if (subscribeBtn && emailInput) {
            subscribeBtn.addEventListener('click', async () => {
                const email = emailInput.value.trim();
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                if (!email || !emailRegex.test(email)) {
                    alert('Please enter a valid email address.');
                    return;
                }

                try {
                    subscribeBtn.disabled = true;
                    subscribeBtn.textContent = 'Subscribing...';

                    const response = await fetch('/subscribe', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({ email })
                    });

                    const result = await response.json();

                    if (response.ok) {
                        alert(result.message);
                        emailInput.value = '';
                    } else {
                        alert(result.message || "Something went wrong. Please try again.");
                    }
                } catch (error) {
                    console.error("Subscription Error:", error);
                    alert("Failed to connect to the server. Please check your connection.");
                } finally {
                    subscribeBtn.disabled = false;
                    subscribeBtn.textContent = 'Subscribe';
                }
            });
        }
    </script>
</body>

