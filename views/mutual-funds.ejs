    <script id="mutualfund-data" type="application/json">
  <%- JSON.stringify(mutualFunds) %>
</script>
    <script>
        /* ── Fund Database ──────────────────────────────────────── */
        const funds = JSON.parse(document.getElementById('mutualfund-data').textContent);


        const catColors = { Equity: 'rgba(59,130,246,.18)', Debt: 'rgba(52,211,153,.12)', Hybrid: 'rgba(197,160,89,.18)', ELSS: 'rgba(167,139,250,.18)', Index: 'rgba(251,191,36,.12)' };
        const catText = { Equity: '#60A5FA', Debt: '#34D399', Hybrid: '#C5A059', ELSS: '#A78BFA', Index: '#FBBF24' };
        const catChip = { Equity: 'chip-eq', Debt: 'chip-debt', Hybrid: 'chip-hybrid', ELSS: 'chip-elss', Index: 'chip-index' };
        const riskColor = { Low: '#34D399', Moderate: '#C5A059', High: '#F87171' };
        const riskBg = { Low: 'rgba(52,211,153,.1)', Moderate: 'rgba(197,160,89,.1)', High: 'rgba(248,113,113,.1)' };

        function stars(n) { return [...Array(5)].map((_, i) => `<span class="${i < n ? 'star-filled' : 'star-empty'} text-sm">★</span>`).join(''); }

        function retBadge(v) { const c = v >= 25 ? 'ret-high' : v >= 12 ? 'ret-mid' : 'ret-low'; return `<span class="ret-badge ${c}">+${v}%</span>`; }

        /* ── Render ── */
        let curCat = 'all', curRisk = 'all', curSort = 'default', curSearch = '';

        function getFiltered() {
            let l = [...funds];
            if (curCat !== 'all') l = l.filter(f => f.cat === curCat);
            if (curRisk !== 'all') l = l.filter(f => f.risk === curRisk);
            if (curSearch) l = l.filter(f => f.name.toLowerCase().includes(curSearch) || f.amc.toLowerCase().includes(curSearch) || f.subCat.toLowerCase().includes(curSearch));
            if (curSort === 'ret1y-high') l.sort((a, b) => b.ret1y - a.ret1y);
            else if (curSort === 'ret3y-high') l.sort((a, b) => b.ret3y - a.ret3y);
            else if (curSort === 'ret5y-high') l.sort((a, b) => b.ret5y - a.ret5y);
            else if (curSort === 'az') l.sort((a, b) => a.name.localeCompare(b.name));
            else l.sort((a, b) => (b.star ? 1 : 0) - (a.star ? 1 : 0) || (b.rating - a.rating));
            return l;
        }

        function renderFunds() {
            const list = getFiltered();
            document.getElementById('fund-count').textContent = list.length;
            const g = document.getElementById('fund-grid'); g.innerHTML = '';
            const em = document.getElementById('fund-empty');
            if (!list.length) { em.classList.remove('hidden'); return; }
            em.classList.add('hidden');
            list.forEach((f, i) => {
                const card = document.createElement('article');
                card.className = 'fund-card p-6 flex flex-col' + (f.star ? ' star-card' : '');
                card.style.animation = `fadeUp .5s cubic-bezier(.23,1,.32,1) ${i * 0.04}s both`;
                card.onclick = () => openFundModal(f);
                card.innerHTML = `
      <div class="flex items-start justify-between mb-4">
        <div>
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <span class="text-xs ${catChip[f.cat]} px-2 py-0.5 rounded-full font-semibold">${f.subCat}</span>
            <span class="text-xs px-2 py-0.5 rounded-full" style="background:${riskBg[f.risk]};color:${riskColor[f.risk]};border:1px solid ${riskColor[f.risk]}44;">${f.risk} Risk</span>
          </div>
          ${f.imglink ? `<img class="w-[50px] h-[50px] object-cover rounded-xl my-5 border-2 border-brand-gold/20" src="${f.imglink}" alt="${f.name}">` : `<div class="w-12 h-12 rounded-xl flex items-center justify-center font-display font-bold text-lg my-5" style="background:${catColors[f.cat]};color:${catText[f.cat]}">${f.amc.substring(0, 2).toUpperCase()}</div>`}
          <h3 class="text-white font-semibold text-sm leading-snug">${f.name}</h3>
          <p class="text-brand-muted text-xs mt-0.5">${f.amc}</p>
        </div>
        ${f.star ? `<span style="background:linear-gradient(135deg,#C5A059,#E5D5B7);color:#08152A;font-size:.5rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;padding:.2rem .5rem;border-radius:9999px;flex-shrink:0">STAR</span>` : ''}
      </div>
      <div class="flex gap-0.5 mb-4">${stars(f.rating)}</div>
      <!-- Returns row -->
      <div class="grid grid-cols-3 gap-2 mb-4">
        <div class="bg-white/3 rounded-lg p-2 text-center">
          <p class="text-white/30 text-xs">1Y</p>
          <p class="font-bold text-xs mt-0.5" style="color:${f.ret1y >= 20 ? '#34D399' : '#C5A059'}">+${f.ret1y}%</p>
        </div>
        <div class="bg-white/3 rounded-lg p-2 text-center">
          <p class="text-white/30 text-xs">3Y</p>
          <p class="font-bold text-xs mt-0.5" style="color:${f.ret3y >= 20 ? '#34D399' : '#C5A059'}">+${f.ret3y}%</p>
        </div>
        <div class="bg-white/3 rounded-lg p-2 text-center">
          <p class="text-white/30 text-xs">5Y</p>
          <p class="font-bold text-xs mt-0.5" style="color:${f.ret5y >= 20 ? '#34D399' : '#C5A059'}">+${f.ret5y}%</p>
        </div>
      </div>
      <div class="flex items-center justify-between mb-5 flex-1">
        <div>
          <p class="text-white/30 text-xs">NAV</p>
          <p class="text-white font-semibold text-sm">${f.nav}</p>
        </div>
        <div class="text-right">
          <p class="text-white/30 text-xs">Min SIP</p>
          <p class="text-brand-gold font-semibold text-sm">${f.minSip}</p>
        </div>
        <div class="text-right">
          <p class="text-white/30 text-xs">AUM</p>
          <p class="text-white/60 text-xs">${f.aum}</p>
        </div>
      </div>
      <button class="btn-gold w-full py-2.5 rounded-lg text-xs flex items-center justify-center gap-1.5 group">
        View Details <span class="material-symbols-outlined text-xs group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
      </button>`;
                g.appendChild(card);
            });
        }

        /* ── Filter events ── */
        document.getElementById('fund-search').addEventListener('input', e => { curSearch = e.target.value.toLowerCase().trim(); renderFunds(); });
        document.getElementById('fund-sort').addEventListener('change', e => { curSort = e.target.value; renderFunds(); });
        document.querySelectorAll('.cat-tab').forEach(btn => btn.addEventListener('click', () => {
            curCat = btn.dataset.cat;
            document.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
            btn.classList.add('active'); renderFunds();
            document.getElementById('fund-listing').scrollIntoView({ behavior: 'smooth' });
        }));
        document.querySelectorAll('.risk-pill').forEach(btn => btn.addEventListener('click', () => {
            curRisk = btn.dataset.risk;
            document.querySelectorAll('.risk-pill').forEach(r => r.classList.remove('active'));
            btn.classList.add('active'); renderFunds();
        }));
        function filterByCategory(cat) {
            curCat = cat;
            document.querySelectorAll('.cat-tab').forEach(t => t.classList.toggle('active', t.dataset.cat === cat));
            renderFunds();
            document.getElementById('fund-listing').scrollIntoView({ behavior: 'smooth' });
        }
        function resetFilters() { curCat = 'all'; curRisk = 'all'; curSort = 'default'; curSearch = ''; document.getElementById('fund-search').value = ''; document.getElementById('fund-sort').value = 'default'; document.querySelectorAll('.cat-tab').forEach(t => t.classList.toggle('active', t.dataset.cat === 'all')); document.querySelectorAll('.risk-pill').forEach(r => r.classList.toggle('active', r.dataset.risk === 'all')); renderFunds(); }

        /* ── Fund Modal ── */
        function openFundModal(f) {
            const av = document.getElementById('m-avatar');
            if (f.imglink) {
                av.innerHTML = `<img src="${f.imglink}" class="w-full h-full object-cover rounded-xl" alt="${f.name}">`;
                av.style.background = 'transparent';
            } else {
                av.textContent = f.amc.substring(0, 2).toUpperCase();
                av.style.background = catColors[f.cat];
                av.style.color = catText[f.cat];
            }
            document.getElementById('m-chip').className = `text-xs px-2 py-0.5 rounded-full font-semibold ${catChip[f.cat]}`;
            document.getElementById('m-chip').textContent = f.subCat;
            const rb = document.getElementById('m-risk-badge');
            rb.textContent = f.risk + ' Risk'; rb.style.cssText = `background:${riskBg[f.risk]};color:${riskColor[f.risk]};border:1px solid ${riskColor[f.risk]}44;border-radius:9999px;padding:.2rem .5rem;font-size:.72rem;`;
            document.getElementById('m-name').textContent = f.name;
            document.getElementById('m-amc').textContent = f.amc + ' · ' + f.subCat;
            document.getElementById('m-nav').textContent = f.nav;
            document.getElementById('m-1y').textContent = '+' + f.ret1y + '%';
            document.getElementById('m-3y').textContent = '+' + f.ret3y + '%';
            document.getElementById('m-5y').textContent = '+' + f.ret5y + '%';
            document.getElementById('m-minsip').textContent = f.minSip;
            document.getElementById('m-desc').textContent = f.desc;
            document.getElementById('m-aum').textContent = f.aum;
            document.getElementById('m-exp').textContent = f.exp;
            document.getElementById('m-exit').textContent = f.exit;
            document.getElementById('m-mgr').textContent = f.mgr;
            const h = document.getElementById('m-holdings'); h.innerHTML = '';
            (f.holdings || []).forEach(s => { const span = document.createElement('span'); span.className = 'text-xs text-white/60 border border-white/10 bg-white/3 px-3 py-1.5 rounded-xl'; span.textContent = s; h.appendChild(span); });
            document.getElementById('fund-modal').classList.add('open');
            document.body.style.overflow = 'hidden';
        }
        function closeModal() { document.getElementById('fund-modal').classList.remove('open'); document.body.style.overflow = ''; }
        document.getElementById('fund-modal').addEventListener('click', e => { if (e.target === document.getElementById('fund-modal')) closeModal(); });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
        function openInvestModal() { document.getElementById('invest-form').scrollIntoView({ behavior: 'smooth' }); }

        /* ── SIP Calculator ── */
        let sipChart = null, growthChart = null;
        function fmtINR(n) { return '₹' + Math.round(n).toLocaleString('en-IN'); }

        function calcSIP() {
            const sip = parseFloat(document.getElementById('sl-sip').value);
            const r = parseFloat(document.getElementById('sl-ret').value) / 100 / 12;
            const n = parseFloat(document.getElementById('sl-dur').value) * 12;
            const stepUp = document.getElementById('step-up-toggle').checked;

            let fv = 0, invested = 0;
            if (stepUp) {
                const annualRate = parseFloat(document.getElementById('sl-ret').value) / 100;
                let monthlySip = sip;
                for (let y = 0; y < n / 12; y++) {
                    for (let m = 0; m < 12; m++) {
                        fv = (fv + monthlySip) * (1 + r);
                        invested += monthlySip;
                    }
                    monthlySip *= 1.1;
                }
            } else {
                fv = sip * (((Math.pow(1 + r, n) - 1) / r) * (1 + r));
                invested = sip * n;
            }

            const gain = fv - invested;
            const roi = ((gain / invested) * 100).toFixed(1);

            document.getElementById('disp-sip').textContent = fmtINR(sip);
            document.getElementById('disp-ret').textContent = parseFloat(document.getElementById('sl-ret').value).toFixed(1) + '%';
            document.getElementById('disp-dur').textContent = parseFloat(document.getElementById('sl-dur').value) + ' years';
            document.getElementById('res-total').textContent = fmtINR(fv);
            document.getElementById('res-invested').textContent = fmtINR(invested);
            document.getElementById('res-gain').textContent = fmtINR(gain);
            document.getElementById('res-roi').textContent = roi + '%';

            /* Donut */
            const circ = 2 * Math.PI * 70;
            const invPct = invested / fv; const gainPct = gain / fv;
            const ctx = document.getElementById('sip-donut').getContext('2d');
            if (sipChart) sipChart.destroy();
            sipChart = new Chart(ctx, {
                type: 'doughnut',
                data: { datasets: [{ data: [Math.round(invested), Math.round(gain)], backgroundColor: ['rgba(197,160,89,.25)', '#C5A059'], borderWidth: 0, hoverOffset: 4 }] },
                options: { responsive: false, cutout: '72%', plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => `${c.label}: ${fmtINR(c.raw)}` }, backgroundColor: 'rgba(13,30,56,.95)', borderColor: 'rgba(197,160,89,.3)', borderWidth: 1, titleColor: 'rgba(240,244,248,.5)', bodyColor: '#C5A059', bodyFont: { family: '"DM Sans"' } } } },
            });

            /* Growth line chart */
            const years = parseFloat(document.getElementById('sl-dur').value);
            const labels = [], invData = [], fvData = [];
            for (let y = 0; y <= years; y++) {
                labels.push(y === 0 ? 'Now' : y + 'Y');
                const nMonths = y * 12;
                let fvY = sip * (((Math.pow(1 + r, nMonths) - 1) / r) * (1 + r));
                invData.push(Math.round(sip * nMonths));
                fvData.push(Math.max(0, Math.round(fvY)));
            }
            const gCtx = document.getElementById('sip-growth-chart').getContext('2d');
            const grad = gCtx.createLinearGradient(0, 0, 0, 160);
            grad.addColorStop(0, 'rgba(197,160,89,.3)');
            grad.addColorStop(1, 'rgba(197,160,89,0)');
            if (growthChart) growthChart.destroy();
            growthChart = new Chart(gCtx, {
                type: 'line',
                data: {
                    labels, datasets: [
                        { label: 'Invested', data: invData, borderColor: 'rgba(197,160,89,.35)', borderWidth: 1.5, pointRadius: 0, tension: .4, fill: false, borderDash: [4, 4] },
                        { label: 'Returns', data: fvData, borderColor: '#C5A059', backgroundColor: grad, borderWidth: 2, pointRadius: 0, tension: .4, fill: true },
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: { backgroundColor: 'rgba(13,30,56,.95)', borderColor: 'rgba(197,160,89,.3)', borderWidth: 1, titleColor: 'rgba(240,244,248,.5)', bodyColor: '#C5A059', callbacks: { label: c => `${c.dataset.label}: ${fmtINR(c.raw)}` } } }, scales: { x: { ticks: { color: 'rgba(240,244,248,.3)', font: { size: 9 } }, grid: { display: false }, border: { display: false } }, y: { display: false } } },
            });
        }

        ['sl-sip', 'sl-ret', 'sl-dur'].forEach(id => document.getElementById(id).addEventListener('input', calcSIP));
        function setPreset(sip, ret, dur) { document.getElementById('sl-sip').value = sip; document.getElementById('sl-ret').value = ret; document.getElementById('sl-dur').value = dur; calcSIP(); }
        calcSIP();

        /* ── FAQs ── */
        const faqs = [
            { q: 'What is the difference between Direct and Regular mutual fund plans?', a: 'Direct plans have no distributor commission, resulting in an expense ratio 0.5–1% lower. Over 20 years, this can translate to 10–15% higher corpus. AKMAY recommends direct plans for most investors.' },
            { q: 'How is SIP different from a lumpsum investment?', a: 'A SIP (Systematic Investment Plan) invests a fixed amount monthly, averaging out market volatility through rupee-cost averaging. A lumpsum invests a large amount at once. SIPs are preferred for salaried investors; lumpsum works when markets are significantly undervalued.' },
            { q: 'What is an ELSS fund and how does it save tax?', a: 'ELSS (Equity Linked Savings Scheme) is a mutual fund with a 3-year lock-in period. Investments up to ₹1.5 Lakhs per year qualify for deduction under Sec. 80C, potentially saving ₹46,800 in tax for the 30% bracket.' },
            { q: 'Are mutual fund returns taxable?', a: 'Equity funds held >1 year: LTCG at 10% on gains above ₹1 Lakh/year. Held <1 year: STCG at 15%. Debt funds: Taxed at income slab rates regardless of holding period (post April 2023). ELSS: Same as equity, but 3-year lock-in.' },
            { q: 'Can I withdraw my SIP at any time?', a: 'Yes, for most open-ended funds there is no mandatory lock-in (except ELSS which has 3 years). You can stop or redeem SIP units at any time. Exit loads may apply if redeemed within 1 year for most equity funds (typically 1% of redemption amount).' },
            { q: 'What minimum amount can I start a SIP with?', a: 'SIPs can start from as low as ₹100–500 per month depending on the fund. Popular funds like Axis Midcap, SBI ELSS, and Edelweiss Hybrid accept SIPs from ₹500. Index funds like Navi Nifty 50 accept ₹10/month.' },
        ];
        const fc = document.getElementById('faq-container');
        faqs.forEach((f, i) => {
            const el = document.createElement('details'); el.className = 'faq-item reveal group'; el.style.transitionDelay = `${i * 0.04}s`;
            el.innerHTML = `<summary class="flex items-center justify-between p-5 cursor-pointer list-none gap-3"><span class="text-white font-medium text-sm">${f.q}</span><span class="faq-icon material-symbols-outlined text-brand-gold flex-shrink-0">add</span></summary><div class="px-5 pb-5 text-brand-muted text-sm leading-relaxed">${f.a}</div>`;
            fc.appendChild(el);
        });

        /* ── MF Form ── */
        ['f-goal', 'f-sip', 'f-risk'].forEach(id => document.getElementById(id).addEventListener('change', function () { this.closest('.field-wrap').classList.toggle('filled', !!this.value); }));
        document.getElementById('mf-form').addEventListener('submit', async e => {
            e.preventDefault();
            const txt = document.getElementById('mf-btn-txt'), ico = document.getElementById('mf-btn-ico'), spin = document.getElementById('mf-spin');
            txt.textContent = 'Sending…'; ico.classList.add('hidden'); spin.classList.remove('hidden');

            try {
                const payload = {
                    formSource: 'Mutual Funds',
                    fullName: document.getElementById('f-name')?.value,
                    emailAddress: document.getElementById('f-email')?.value,
                    phoneNumber: document.getElementById('f-phone')?.value,
                    goal: document.getElementById('f-goal')?.value,
                    sipAmount: document.getElementById('f-sip')?.value,
                    riskProfile: document.getElementById('f-risk')?.value
                };
                const res = await fetch('/send-email', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (!res.ok) throw new Error('Failed');
                document.getElementById('mf-form').reset();
                ['f-goal', 'f-sip', 'f-risk'].forEach(id => {
                    const el = document.getElementById(id);
                    if (el) el.closest('.field-wrap').classList.remove('filled');
                });
                document.getElementById('success-overlay').classList.add('show');
            } catch (err) {
                alert('An error occurred. Please try again.');
            } finally {
                spin.classList.add('hidden'); ico.classList.remove('hidden'); txt.textContent = 'Request Advisory';
            }
        });

        /* ── Nav + scroll ── */
        const nav = document.getElementById('topnav'), fc2 = document.getElementById('float-cta');
        window.addEventListener('scroll', () => { nav.classList.toggle('scrolled', window.scrollY > 60); fc2.classList.toggle('show', window.scrollY > 500); });

        /* ── Reveal ── */
        const rvio = new IntersectionObserver(e => { e.forEach(x => { if (x.isIntersecting) { x.target.classList.add('up'); rvio.unobserve(x.target); } }); }, { threshold: .1 });
        document.querySelectorAll('.reveal,.reveal-l,.reveal-r,.faq-item').forEach(el => rvio.observe(el));

        /* ── Init ── */
        renderFunds();
    </script>
</body>

</html>