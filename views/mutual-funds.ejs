        .gold-text {
            background: linear-gradient(135deg, #C5A059 0%, #E5D5B7 45%, #C5A059 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .gline {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold) 30%, var(--gold2) 60%, var(--gold) 80%, transparent);
        }

        .glass {
            background: rgba(255, 255, 255, .035);
            backdrop-filter: blur(18px);
            border: 1px solid rgba(197, 160, 89, .18);
        }

        .sec-label {
            font-size: .65rem;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: rgba(197, 160, 89, .6);
            font-weight: 600;
        }

        .btn-gold {
            background: linear-gradient(135deg, #C5A059 0%, #E5D5B7 50%, #C5A059 100%);
            background-size: 200% auto;
            color: #08152A;
            font-weight: 700;
            transition: background-position .5s, transform .2s, box-shadow .3s;
        }

        .btn-gold:hover {
            background-position: right center;
            transform: translateY(-2px);
            box-shadow: 0 16px 40px rgba(197, 160, 89, .3);
        }

        .btn-ghost {
            border: 1px solid rgba(197, 160, 89, .45);
            color: var(--gold2);
            font-weight: 600;
            transition: background .3s, border-color .3s, transform .2s;
        }

        .btn-ghost:hover {
            background: rgba(197, 160, 89, .08);
            border-color: rgba(197, 160, 89, .7);
            transform: translateY(-2px);
        }

        /* ── Reveal ── */
        .reveal {
            opacity: 0;
            transform: translateY(24px);
            transition: opacity .7s ease, transform .7s cubic-bezier(.23, 1, .32, 1);
        }

        .reveal.up {
            opacity: 1;
            transform: none;
        }

        .reveal-l {
            opacity: 0;
            transform: translateX(-24px);
            transition: opacity .7s ease, transform .7s cubic-bezier(.23, 1, .32, 1);
        }

        .reveal-l.up {
            opacity: 1;
            transform: none;
        }

        .reveal-r {
            opacity: 0;
            transform: translateX(24px);
            transition: opacity .7s ease, transform .7s cubic-bezier(.23, 1, .32, 1);
        }

        .reveal-r.up {
            opacity: 1;
            transform: none;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(32px)
            }

            to {
                opacity: 1;
                transform: none
            }
        }

        .ha1 {
            animation: fadeUp .85s cubic-bezier(.23, 1, .32, 1) .1s both;
        }

        .ha2 {
            animation: fadeUp .85s cubic-bezier(.23, 1, .32, 1) .25s both;
        }

        .ha3 {
            animation: fadeUp .85s cubic-bezier(.23, 1, .32, 1) .4s both;
        }

        .ha4 {
            animation: fadeUp .85s cubic-bezier(.23, 1, .32, 1) .52s both;
        }

        /* ── Ticker ── */
        .ticker-wrap {
            overflow: hidden;
        }

        .ticker-inner {
            display: flex;
            gap: 3rem;
            white-space: nowrap;
            animation: ticker 30s linear infinite;
        }

        @keyframes ticker {
            from {
                transform: translateX(0)
            }

            to {
                transform: translateX(-50%)
            }
        }

        /* ── Float CTA ── */
        #float-cta {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            z-index: 90;
            opacity: 0;
            transform: translateY(10px);
            transition: opacity .4s, transform .4s;
            pointer-events: none;
        }

        #float-cta.show {
            opacity: 1;
            transform: none;
            pointer-events: auto;
        }

        /* ── Category tabs ── */
        .cat-tab {
            padding: .55rem 1.25rem;
            border-radius: 9999px;
            font-size: .8rem;
            font-weight: 500;
            cursor: pointer;
            border: 1px solid rgba(197, 160, 89, .2);
            color: rgba(240, 244, 248, .45);
            transition: all .2s;
            background: transparent;
            white-space: nowrap;
        }

        .cat-tab:hover {
            background: rgba(197, 160, 89, .08);
            color: rgba(240, 244, 248, .8);
        }

        .cat-tab.active {
            background: rgba(197, 160, 89, .18);
            border-color: rgba(197, 160, 89, .55);
            color: #C5A059;
        }

        /* ── Risk filter ── */
        .risk-pill {
            border: 1px solid rgba(255, 255, 255, .1);
            color: rgba(240, 244, 248, .4);
            font-size: .72rem;
            font-weight: 500;
            padding: .28rem .75rem;
            border-radius: 9999px;
            cursor: pointer;
            transition: all .2s;
            background: transparent;
        }

        .risk-pill:hover,
        .risk-pill.active {
            background: rgba(197, 160, 89, .1);
            border-color: rgba(197, 160, 89, .45);
            color: #C5A059;
        }

        /* ── Sort ── */
        .sort-sel {
            background: rgba(255, 255, 255, .04);
            border: 1px solid rgba(197, 160, 89, .2);
            color: rgba(240, 244, 248, .6);
            border-radius: .5rem;
            padding: .4rem .8rem;
            font-size: .75rem;
            font-family: "DM Sans", sans-serif;
            cursor: pointer;
            outline: none;
            transition: border-color .3s;
        }

        .sort-sel:focus {
            border-color: rgba(197, 160, 89, .5);
        }

        .sort-sel option {
            background: #0D1E38;
        }

        /* ── Search ── */
        .search-box {
            background: rgba(255, 255, 255, .04) !important;
            border: 1px solid rgba(197, 160, 89, .2);
            color: #F0F4F8;
            transition: border-color .3s, background .3s;
        }

        .search-box:focus {
            outline: none;
            border-color: rgba(197, 160, 89, .6) !important;
            background: rgba(255, 255, 255, .06);
            box-shadow: none;
        }

        .search-box::placeholder {
            color: rgba(240, 244, 248, .25);
        }

        /* ── Fund card ── */
        .fund-card {
            border: 1px solid rgba(197, 160, 89, .1);
            background: rgba(255, 255, 255, .022);
            border-radius: 1.125rem;
            transition: border-color .3s, background .3s, transform .4s cubic-bezier(.23, 1, .32, 1), box-shadow .3s;
            overflow: hidden;
            position: relative;
            cursor: pointer;
        }

        .fund-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at top right, rgba(197, 160, 89, .055), transparent 65%);
            opacity: 0;
            transition: opacity .35s;
            pointer-events: none;
        }

        .fund-card:hover {
            border-color: rgba(197, 160, 89, .4);
            background: rgba(197, 160, 89, .035);
            transform: translateY(-5px);
            box-shadow: 0 28px 56px rgba(0, 0, 0, .4);
        }

        .fund-card:hover::before {
            opacity: 1;
        }

        .fund-card.star-card {
            border-color: rgba(197, 160, 89, .32);
            background: linear-gradient(145deg, rgba(197, 160, 89, .1), rgba(197, 160, 89, .03));
        }

        /* ── Risk meter ── */
        .risk-dot {
            width: .55rem;
            height: .55rem;
            border-radius: 50%;
            flex-shrink: 0;
        }

        /* ── Rating stars ── */
        .star-filled {
            color: #C5A059;
        }

        .star-empty {
            color: rgba(197, 160, 89, .25);
        }

        /* ── Return badge ── */
        .ret-badge {
            font-size: .72rem;
            font-weight: 700;
            padding: .2rem .55rem;
            border-radius: .4rem;
        }

        .ret-high {
            background: rgba(52, 211, 153, .12);
            color: #34D399;
            border: 1px solid rgba(52, 211, 153, .25);
        }

        .ret-mid {
            background: rgba(197, 160, 89, .12);
            color: #C5A059;
            border: 1px solid rgba(197, 160, 89, .3);
        }

        .ret-low {
            background: rgba(248, 113, 113, .1);
            color: #F87171;
            border: 1px solid rgba(248, 113, 113, .25);
        }

        /* ── Category colour chips ── */
        .chip-eq {
            background: rgba(59, 130, 246, .12);
            color: #60A5FA;
            border: 1px solid rgba(59, 130, 246, .25);
        }

        .chip-debt {
            background: rgba(52, 211, 153, .1);
            color: #34D399;
            border: 1px solid rgba(52, 211, 153, .2);
        }

        .chip-hybrid {
            background: rgba(197, 160, 89, .15);
            color: #C5A059;
            border: 1px solid rgba(197, 160, 89, .3);
        }

        .chip-elss {
            background: rgba(167, 139, 250, .12);
            color: #A78BFA;
            border: 1px solid rgba(167, 139, 250, .25);
        }

        .chip-index {
            background: rgba(251, 191, 36, .1);
            color: #FBBF24;
            border: 1px solid rgba(251, 191, 36, .2);
        }

        /* ── SIP Calculator ── */
        .sip-slider {
            -webkit-appearance: none;
            appearance: none;
            width: 100%;
            height: 4px;
            background: rgba(197, 160, 89, .2);
            border-radius: 2px;
            outline: none;
            cursor: pointer;
        }

        .sip-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: var(--gold);
            border: 3px solid var(--navy2);
            cursor: pointer;
            box-shadow: 0 0 0 4px rgba(197, 160, 89, .2);
        }

        .sip-slider::-moz-range-thumb {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: var(--gold);
            border: 3px solid var(--navy2);
        }

        /* ── Donut chart ── */
        .donut-wrap {
            position: relative;
            width: 180px;
            height: 180px;
            flex-shrink: 0;
        }

        .donut-label {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        /* ── FAQ ── */
        .faq-item {
            border: 1px solid rgba(197, 160, 89, .12);
            border-radius: 1rem;
            overflow: hidden;
            transition: border-color .3s;
        }

        .faq-item:hover {
            border-color: rgba(197, 160, 89, .35);
        }

        .faq-icon {
            transition: transform .3s;
            display: inline-block;
        }

        details[open] .faq-icon {
            transform: rotate(45deg);
        }

        /* ── Fund modal ── */
        #fund-modal {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(8, 21, 42, .87);
            backdrop-filter: blur(14px);
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        #fund-modal.open {
            display: flex;
        }

        .modal-box {
            background: linear-gradient(145deg, #0D1E38, #08152A);
            border: 1px solid rgba(197, 160, 89, .25);
            border-radius: 1.5rem;
            max-width: 680px;
            width: 100%;
            position: relative;
            max-height: 95vh;
            overflow-y: auto;
        }

        @keyframes mIn {
            from {
                opacity: 0;
                transform: scale(.93) translateY(20px)
            }

            to {
                opacity: 1;
                transform: none
            }
        }

        .modal-box {
            animation: mIn .35s cubic-bezier(.23, 1, .32, 1) both;
        }

        /* ── Enquiry form ── */
        .field-wrap {
            position: relative;
            margin-bottom: 1.5rem;
        }

        .field-wrap input,
        .field-wrap select,
        .field-wrap textarea {
            width: 100%;
            background: transparent;
            border: none;
            border-bottom: 1px solid rgba(197, 160, 89, .3);
            padding: 1.25rem 0 .45rem;
            font-size: .875rem;
            color: #F0F4F8;
            outline: none;
            transition: border-color .3s;
            font-family: "DM Sans", sans-serif;
            resize: none;
        }

        .field-wrap select option {
            background: #0D1E38;
        }

        .field-wrap input:focus,
        .field-wrap select:focus,
        .field-wrap textarea:focus {
            border-bottom-color: #C5A059;
        }

        .field-wrap label {
            position: absolute;
            top: 1.2rem;
            left: 0;
            font-size: .8rem;
            color: rgba(240, 244, 248, .35);
            pointer-events: none;
            transition: top .25s, font-size .25s, color .25s;
        }

        .field-wrap input:focus~label,
        .field-wrap input:not(:placeholder-shown)~label,
        .field-wrap textarea:focus~label,
        .field-wrap textarea:not(:placeholder-shown)~label,
        .field-wrap.filled label {
            top: .05rem;
            font-size: .65rem;
            color: #C5A059;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .field-wrap .ubar {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 1px;
            background: #C5A059;
            transition: width .4s cubic-bezier(.23, 1, .32, 1);
        }

        .field-wrap input:focus~.ubar,
        .field-wrap select:focus~.ubar,
        .field-wrap textarea:focus~.ubar {
            width: 100%;
        }

        /* ── Success overlay ── */
        #success-overlay {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 99999;
            background: rgba(8, 21, 42, .96);
            backdrop-filter: blur(10px);
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 2rem;
        }

        #success-overlay.show {
            display: flex;
        }

        /* ── Category feature cards ── */
        .feature-card {
            border: 1px solid rgba(197, 160, 89, .1);
            background: rgba(255, 255, 255, .02);
            border-radius: 1.25rem;
            transition: border-color .35s, background .35s, transform .4s cubic-bezier(.23, 1, .32, 1);
        }

        .feature-card:hover {
            border-color: rgba(197, 160, 89, .4);
            background: rgba(197, 160, 89, .04);
            transform: translateY(-5px);
        }

        ::-webkit-scrollbar {
            width: 4px;
        }

        ::-webkit-scrollbar-track {
            background: var(--navy);
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(197, 160, 89, .4);
            border-radius: 2px;
        }
    </style>
</head>

