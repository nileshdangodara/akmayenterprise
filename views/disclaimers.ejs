            }
        };

        let currentPage = 'disclaimer';

        function switchPage(page) {
            currentPage = page;
            const cfg = pages[page];

            /* Meta */
            document.getElementById('pg-title').textContent = cfg.title;
            document.getElementById('pg-canonical').href = cfg.canonical;
            document.getElementById('pg-heading').innerHTML = cfg.heading;
            document.getElementById('pg-subline').textContent = cfg.subline;
            document.getElementById('bc-current').textContent = cfg.bc;

            /* Sections */
            document.querySelectorAll('.legal-section').forEach(s => s.classList.remove('active'));
            document.getElementById('sec-' + page).classList.add('active');

            /* Tabs */
            document.querySelectorAll('.page-tab').forEach(t => t.classList.toggle('active', t.dataset.page === page));

            /* TOC */
            buildTOC(cfg.toc);

            /* Side links */
            ['disclaimer', 'privacy', 'terms'].forEach(p => {
                const el = document.getElementById('side-' + p);
                if (el) el.classList.toggle('active', p === page);
            });

            /* Scroll to top of content */
            document.querySelector('.max-w-7xl.mx-auto.px-4.sm\\:px-6').scrollIntoView({ behavior: 'smooth', block: 'start' });

            /* Re-trigger reveal for newly shown section */
            const activeSection = document.getElementById('sec-' + page);
            activeSection.querySelectorAll('h2,h3,p,.highlight-box,.warn-box').forEach(el => {
                el.style.opacity = '';
                el.style.transform = '';
            });

            /* Refresh scroll spy */
            observeHeadings();
        }

        function buildTOC(items) {
            const nav = document.getElementById('toc-nav');
            nav.innerHTML = '';
            items.forEach(item => {
                const a = document.createElement('a');
                a.href = '#' + item.id;
                a.className = 'toc-link';
                a.textContent = item.label;
                a.addEventListener('click', e => {
                    e.preventDefault();
                    const el = document.getElementById(item.id);
                    if (el) {
                        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        setTimeout(() => highlightTOC(item.id), 400);
                    }
                });
                nav.appendChild(a);
            });
        }

        function highlightTOC(activeId) {
            document.querySelectorAll('#toc-nav .toc-link').forEach(a => {
                a.classList.toggle('active', a.getAttribute('href') === '#' + activeId);
            });
        }

        /* Active TOC on scroll */
        const obs = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    const id = e.target.id;
                    if (id) highlightTOC(id);
                }
            });
        }, { rootMargin: '-15% 0px -80% 0px', threshold: 0 });

        function observeHeadings() {
            obs.disconnect();
            const activeSection = document.getElementById('sec-' + currentPage);
            activeSection.querySelectorAll('h2[id],h3[id]').forEach(h => obs.observe(h));
        }

        /* Init */
        buildTOC(pages.disclaimer.toc);
        observeHeadings();

        /* Check URL params for initial page */
        const urlParams = new URLSearchParams(window.location.search);
        const pg = urlParams.get('page');
        if (pg && pages[pg]) switchPage(pg);

        /* Nav scroll */
        const nav = document.getElementById('topnav');
        window.addEventListener('scroll', () => nav.classList.toggle('scrolled', window.scrollY > 60));

        /* Reveal */
        const rvio = new IntersectionObserver(e => {
            e.forEach(x => { if (x.isIntersecting) { x.target.classList.add('up'); rvio.unobserve(x.target); } });
        }, { threshold: 0.06 });
        document.querySelectorAll('.reveal').forEach(el => rvio.observe(el));
    </script>
</body>

</html>