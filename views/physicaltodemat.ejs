        }

        .mob-drop-toggle:checked~label .di {
            transform: rotate(180deg);
        }

        /* ── Core ── */
        .gold-text {
            background: linear-gradient(135deg, #C5A059 0%, #E5D5B7 45%, #C5A059 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .gline {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold) 30%, var(--gold2) 60%, var(--gold) 80%, transparent);
        }

        .glass {
            background: rgba(255, 255, 255, .035);
            backdrop-filter: blur(18px);
            border: 1px solid rgba(197, 160, 89, .18);
        }

        .sec-label {
            font-size: .65rem;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: rgba(197, 160, 89, .6);
            font-weight: 600;
        }

        .btn-gold {
            background: linear-gradient(135deg, #C5A059 0%, #E5D5B7 50%, #C5A059 100%);
            background-size: 200% auto;
            color: #08152A;
            font-weight: 700;
            transition: background-position .5s, transform .2s, box-shadow .3s;
        }

        .btn-gold:hover {
            background-position: right center;
            transform: translateY(-2px);
            box-shadow: 0 16px 40px rgba(197, 160, 89, .3);
        }

        .btn-ghost {
            border: 1px solid rgba(197, 160, 89, .45);
            color: var(--gold2);
            font-weight: 600;
            transition: background .3s, border-color .3s, transform .2s;
        }

        .btn-ghost:hover {
            background: rgba(197, 160, 89, .08);
            border-color: rgba(197, 160, 89, .7);
            transform: translateY(-2px);
        }

        /* ── Scroll reveal ── */
        .reveal {
            opacity: 0;
            transform: translateY(24px);
            transition: opacity .7s ease, transform .7s cubic-bezier(.23, 1, .32, 1);
        }

        .reveal.up {
            opacity: 1;
            transform: none;
        }

        .reveal-l {
            opacity: 0;
            transform: translateX(-24px);
            transition: opacity .7s ease, transform .7s cubic-bezier(.23, 1, .32, 1);
        }

        .reveal-l.up {
            opacity: 1;
            transform: none;
        }

        .reveal-r {
            opacity: 0;
            transform: translateX(24px);
            transition: opacity .7s ease, transform .7s cubic-bezier(.23, 1, .32, 1);
        }

        .reveal-r.up {
            opacity: 1;
            transform: none;
        }

        /* ── Hero anims ── */
        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(36px)
            }

            to {
                opacity: 1;
                transform: none
            }
        }

        @keyframes scaleIn {
            from {
                opacity: 0;
                transform: scale(.93)
            }

            to {
                opacity: 1;
                transform: scale(1)
            }
        }

        .ha1 {
            animation: fadeUp .85s cubic-bezier(.23, 1, .32, 1) .1s both;
        }

        .ha2 {
            animation: fadeUp .85s cubic-bezier(.23, 1, .32, 1) .25s both;
        }

        .ha3 {
            animation: fadeUp .85s cubic-bezier(.23, 1, .32, 1) .4s both;
        }

        .ha4 {
            animation: scaleIn 1s cubic-bezier(.23, 1, .32, 1) .45s both;
        }

        /* ── Float CTA ── */
        #float-cta {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            z-index: 90;
            opacity: 0;
            transform: translateY(10px);
            transition: opacity .4s, transform .4s;
            pointer-events: none;
        }

        #float-cta.show {
            opacity: 1;
            transform: none;
            pointer-events: auto;
        }

        /* ── Ticker ── */
        .ticker-wrap {
            overflow: hidden;
        }

        .ticker-inner {
            display: flex;
            gap: 3rem;
            white-space: nowrap;
            animation: ticker 28s linear infinite;
        }

        @keyframes ticker {
            from {
                transform: translateX(0)
            }

            to {
                transform: translateX(-50%)
            }
        }

        /* ── Process stepper ── */
        .step-item {
            cursor: pointer;
            transition: opacity .3s;
        }

        .step-item:not(.active) {
            opacity: .45;
        }

        .step-item:hover {
            opacity: .8;
        }

        .step-item.active {
            opacity: 1;
        }

        .step-dot {
            width: 2.5rem;
            height: 2.5rem;
            border-radius: 50%;
            border: 2px solid rgba(197, 160, 89, .3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: "Cormorant Garamond", serif;
            font-weight: 700;
            font-size: 1rem;
            transition: background .35s, border-color .35s, color .35s;
            flex-shrink: 0;
            color: rgba(197, 160, 89, .4);
        }

        .step-item.active .step-dot {
            background: var(--gold);
            border-color: var(--gold);
            color: #08152A;
        }

        .step-item.done .step-dot {
            background: rgba(52, 211, 153, .15);
            border-color: #34D399;
            color: #34D399;
        }

        .step-connector {
            flex: 1;
            height: 1px;
            background: rgba(197, 160, 89, .15);
            min-width: 1.5rem;
        }

        .step-content-panel {
            display: none;
        }

        .step-content-panel.active {
            display: block;
        }

        /* ── Document checklist ── */
        .doc-item {
            border: 1px solid rgba(197, 160, 89, .1);
            border-radius: .875rem;
            transition: border-color .3s, background .3s;
        }

        .doc-item:hover {
            border-color: rgba(197, 160, 89, .35);
            background: rgba(197, 160, 89, .03);
        }

        .doc-item.checked {
            border-color: rgba(52, 211, 153, .3);
            background: rgba(52, 211, 153, .04);
        }

        .custom-cb {
            width: 1.25rem;
            height: 1.25rem;
            border-radius: .3rem;
            border: 1.5px solid rgba(197, 160, 89, .4);
            background: transparent;
            appearance: none;
            cursor: pointer;
            transition: background .2s, border-color .2s;
            flex-shrink: 0;
        }

        .custom-cb:checked {
            background: #34D399;
            border-color: #34D399;
        }

        .doc-item.checked .doc-name {
            color: rgba(240, 244, 248, .45);
            text-decoration: line-through;
        }

        /* ── Progress ring ── */
        .progress-ring-bg {
            stroke: rgba(197, 160, 89, .12);
        }

        .progress-ring-fill {
            stroke: var(--gold);
            stroke-linecap: round;
            transform: rotate(-90deg);
            transform-origin: 50% 50%;
            transition: stroke-dashoffset .5s cubic-bezier(.23, 1, .32, 1);
        }

        /* ── Comparison table ── */
        .cmp-row {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 0;
        }

        .cmp-cell {
            padding: .85rem 1.25rem;
            border-bottom: 1px solid rgba(197, 160, 89, .07);
            font-size: .8rem;
        }

        .cmp-row:last-child .cmp-cell {
            border-bottom: none;
        }

        .cmp-header {
            background: rgba(255, 255, 255, .03);
        }

        .cmp-good {
            color: #34D399;
        }

        .cmp-bad {
            color: #F87171;
        }

        /* ── Timeline visual ── */
        .tl-bar {
            position: relative;
            height: 4px;
            background: rgba(197, 160, 89, .1);
            border-radius: 2px;
            overflow: hidden;
        }

        .tl-fill {
            height: 100%;
            border-radius: 2px;
            background: linear-gradient(90deg, var(--gold), var(--gold2));
            transition: width .8s cubic-bezier(.23, 1, .32, 1);
        }

        .tl-node {
            width: .875rem;
            height: .875rem;
            border-radius: 50%;
            border: 2px solid var(--gold);
            background: var(--navy2);
            flex-shrink: 0;
            transition: background .3s;
        }

        .tl-node.filled {
            background: var(--gold);
        }

        /* ── FAQ ── */
        .faq-item {
            border: 1px solid rgba(197, 160, 89, .12);
            border-radius: 1rem;
            overflow: hidden;
            transition: border-color .3s;
        }

        .faq-item:hover {
            border-color: rgba(197, 160, 89, .35);
        }

        .faq-icon {
            transition: transform .3s;
            display: inline-block;
        }

