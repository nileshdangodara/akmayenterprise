                    <a href="#" class="hover:text-brand-gold transition-colors">Terms of Service</a>
                    <a href="#" class="hover:text-brand-gold transition-colors">Disclaimer</a>
                    <a href="#" class="hover:text-brand-gold transition-colors">SEBI Compliance</a>
                    <a href="/contact" class="hover:text-brand-gold transition-colors">Contact Us</a>
                </div>
            </div>

            <p class="text-xs text-white/15 mt-6 text-center max-w-2xl mx-auto leading-relaxed">
                Investment in securities market is subject to market risks. Read all the related documents carefully
                before investing. Past performance is not indicative of future returns. AKMAY Enterprise LLP facilitates
                transactions through SEBI-registered entities.
            </p>
        </div>
    </footer>

    <!-- ── Success overlay ── -->
    <div id="success-overlay">
        <div class="max-w-md w-full text-center">
            <div
                class="w-16 h-16 rounded-full bg-brand-gold/10 border border-brand-gold/30 flex items-center justify-center mx-auto mb-6">
                <span class="material-symbols-outlined text-brand-gold text-3xl">check_circle</span>
            </div>
            <h2 class="font-display text-3xl text-white font-semibold mb-3">Request Received</h2>
            <p class="text-brand-muted text-sm mb-8 max-w-sm mx-auto leading-relaxed">An AKMAY advisor will contact you
                within one business day with a personalised conversion roadmap.</p>
            <button onclick="document.getElementById('success-overlay').classList.remove('show')"
                class="btn-gold px-8 py-3 rounded-xl text-sm">Back to Page</button>
        </div>
    </div>

    <!-- ══════════════════ SCRIPTS ══════════════════ -->
    <script>
        /* ── Documents list ── */
        const docs = [
            { id: 'd1', label: 'Original share certificate(s)', required: true, note: 'Physical copy with company seal' },
            { id: 'd2', label: 'Dematerialisation Request Form (DRF)', required: true, note: 'We provide and fill this for you' },
            { id: 'd3', label: 'PAN Card (self-attested copy)', required: true, note: 'Mandatory for all transactions' },
            { id: 'd4', label: 'Aadhaar Card (self-attested copy)', required: true, note: 'For KYC verification' },
            { id: 'd5', label: 'Demat Account details (DP ID + Client ID)', required: true, note: 'From your DP welcome kit' },
            { id: 'd6', label: 'Cancelled cheque or bank passbook copy', required: false, note: 'For dividend mandate linking' },
            { id: 'd7', label: 'Passport-size photograph', required: false, note: '2 copies, recent' },
            { id: 'd8', label: 'Signature attestation (if name mismatch)', required: false, note: 'Needed only if name differs on cert vs PAN' },
        ];

        const checklist = document.getElementById('doc-checklist');
        const checked = new Set();

        function updateProgress() {
            const total = docs.length;
            const done = checked.size;
            const pct = Math.round((done / total) * 100);
            const r = 26, circ = 2 * Math.PI * r;
            const offset = circ - (pct / 100) * circ;
            document.getElementById('prog-ring').style.strokeDashoffset = offset;
            document.getElementById('prog-text').textContent = pct + '%';
            document.getElementById('prog-sub').textContent = `${done} of ${total} documents collected`;
            document.getElementById('prog-label').textContent = done === 0 ? 'Start ticking items above' : done === total ? '✓ All documents ready!' : `${total - done} more to go`;
        }

        docs.forEach(d => {
            const wrap = document.createElement('label');
            wrap.className = 'doc-item flex items-start gap-3 p-4 cursor-pointer';
            wrap.htmlFor = d.id;
            wrap.innerHTML = `
    <input type="checkbox" class="custom-cb mt-0.5" id="${d.id}" />
    <div class="flex-1 min-w-0">
      <p class="doc-name text-white text-sm font-medium leading-tight">${d.label} ${d.required ? '<span class="text-brand-gold text-xs">*</span>' : ''}</p>
      <p class="text-white/30 text-xs mt-0.5">${d.note}</p>
    </div>
    <span class="material-symbols-outlined text-white/20 text-lg check-icon flex-shrink-0">check_circle</span>
  `;
            checklist.appendChild(wrap);
            document.getElementById(d.id).addEventListener('change', function () {
                if (this.checked) { checked.add(d.id); wrap.classList.add('checked'); wrap.querySelector('.check-icon').style.color = '#34D399'; }
                else { checked.delete(d.id); wrap.classList.remove('checked'); wrap.querySelector('.check-icon').style.color = ''; }
                updateProgress();
            });
        });
        updateProgress();

        /* ── Step logic ── */
        function goStep(n) {
            document.querySelectorAll('.step-item').forEach((el, i) => {
                const sn = i + 1;
                el.classList.toggle('active', sn === n);
                el.classList.toggle('done', sn < n);
            });
            document.querySelectorAll('.step-content-panel').forEach(p => {
                p.classList.toggle('active', parseInt(p.dataset.panel) === n);
            });
            document.getElementById('process-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        document.querySelectorAll('.step-item').forEach((el, i) => {
            el.addEventListener('click', () => goStep(i + 1));
        });

        /* ── FAQ data ── */
        const faqs = [
            { q: 'What if my name on the certificate doesn\'t match my PAN?', a: 'This is very common — especially with old certificates. We prepare an affidavit or indemnity bond that resolves the discrepancy before submission, ensuring first-time RTA approval.' },
            { q: 'Can I convert certificates for companies that have merged or changed names?', a: 'Yes. We handle corporate action histories including mergers, demergers, and name changes. We trace the current RTA and process accordingly.' },
            { q: 'What if the certificate is damaged or has missing details?', a: 'Damaged certificates can still be dematerialised in most cases. We assess the extent of damage and initiate a duplicate certificate process with the company\'s RTA if required before submitting for demat.' },
            { q: 'Do I need a Demat account before starting?', a: 'Yes, a Demat account is required to receive the shares. If you don\'t have one, we guide you through opening one with a SEBI-registered Depository Participant at no extra complexity.' },
            { q: 'What is the cost of the Physical to Demat conversion?', a: 'The conversion itself is generally at cost — primarily the DP\'s processing charges (typically ₹25–50 per certificate, plus applicable taxes). AKMAY charges an advisory fee for the end-to-end facilitation, which we discuss upfront with full transparency.' },
            { q: 'Can inherited or gifted shares be dematerialised?', a: 'Yes, inherited shares require transmission to your name first before dematerialisation. We handle the full succession/transmission process, including obtaining legal heir certificates or succession certificates where needed.' },
            { q: 'How do I track the status of my conversion?', a: 'Once a Dematerialisation Request Number (DRN) is generated, we share it with you for real-time tracking on your DP\'s portal. We also proactively update you at every milestone.' },
        ];

        const faqList = document.getElementById('faq-list');
        faqs.forEach((f, i) => {
            const item = document.createElement('details');
            item.className = 'faq-item reveal group';
            item.style.transitionDelay = `${i * 0.04}s`;
            item.innerHTML = `
    <summary class="flex items-center justify-between p-5 cursor-pointer list-none gap-3">
      <span class="text-white font-medium text-sm">${f.q}</span>
      <span class="faq-icon material-symbols-outlined text-brand-gold flex-shrink-0">add</span>
    </summary>
    <div class="px-5 pb-5 text-brand-muted text-sm leading-relaxed">${f.a}</div>
  `;
            faqList.appendChild(item);
        });

        /* ── Form select filled ── */
        document.getElementById('f-certs').addEventListener('change', function () {
            this.closest('.field-wrap').classList.toggle('filled', !!this.value);
        });

        /* ── Form submit ── */
        document.getElementById('demat-form').addEventListener('submit', async e => {
            e.preventDefault();
            const txt = document.getElementById('submit-text');
            const icon = document.getElementById('submit-icon');
            const spin = document.getElementById('submit-spin');
            txt.textContent = 'Sending…';
            icon.classList.add('hidden');
            spin.classList.remove('hidden');

            try {
                const payload = {
                    formSource: 'Physical to Demat',
                    fullName: document.getElementById('f-name')?.value,
                    emailAddress: document.getElementById('f-email')?.value,
                    phoneNumber: document.getElementById('f-phone')?.value,
                    certificates: document.getElementById('f-certs')?.value,
                    company: document.getElementById('f-company')?.value,
                    query: document.getElementById('f-query')?.value
                };
                const res = await fetch('/send-email', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (!res.ok) throw new Error('Failed');
                document.getElementById('demat-form').reset();
                const fCerts = document.getElementById('f-certs');
                if (fCerts) fCerts.closest('.field-wrap').classList.remove('filled');
                document.getElementById('success-overlay').classList.add('show');
            } catch (err) {
                alert('An error occurred. Please try again.');
            } finally {
                spin.classList.add('hidden');
                icon.classList.remove('hidden');
                txt.textContent = 'Send Request';
            }
        });

        /* ── Scroll & nav ── */
        const nav = document.getElementById('topnav');
        const floatCta = document.getElementById('float-cta');
        window.addEventListener('scroll', () => {
            nav.classList.toggle('scrolled', window.scrollY > 60);
            floatCta.classList.toggle('show', window.scrollY > 500);
        });

        const rvio = new IntersectionObserver(entries => {
            entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('up'); rvio.unobserve(e.target); } });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal,.reveal-l,.reveal-r,.faq-item').forEach(el => rvio.observe(el));

        /* ── Newsletter Subscription ── */
        const subscribeBtn = document.getElementById('subscribe-btn');
        const emailInput = document.getElementById('subscriber-email');

        if (subscribeBtn && emailInput) {
            subscribeBtn.addEventListener('click', async () => {
                const email = emailInput.value.trim();
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                if (!email || !emailRegex.test(email)) {
                    alert('Please enter a valid email address.');
                    return;
                }

                try {
                    subscribeBtn.disabled = true;
                    subscribeBtn.textContent = 'Subscribing...';

                    const response = await fetch('/subscribe', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({ email })
                    });

                    const result = await response.json();

                    if (response.ok) {
                        alert(result.message);
                        emailInput.value = '';
                    } else {
                        alert(result.message || "Something went wrong. Please try again.");
                    }
                } catch (error) {
                    console.error("Subscription Error:", error);
                    alert("Failed to connect to the server. Please check your connection.");
                } finally {
                    subscribeBtn.disabled = false;
                    subscribeBtn.textContent = 'Subscribe';
                }
            });
        }
    </script>
</body>

</html>