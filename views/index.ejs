        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Physical to Demat"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Fixed Deposits"}}
      ]
    },
    "contactPoint": {"@type": "ContactPoint", "contactType": "Customer Service", "availableLanguage": ["English","Hindi"]}
  }
